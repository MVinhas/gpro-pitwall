# Front controller — every request that doesn't map to a real file goes to index.php.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Hide dotfiles (.env, .git, .htaccess itself).
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block direct access to SQLite databases and their sidecar files,
# in case the DB ever lands under docroot.
<FilesMatch "\.(sqlite|sqlite-shm|sqlite-wal|db)$">
    Require all denied
</FilesMatch>

# Block direct PHP access except for the front controller. Defence in depth
# against stray scripts ending up in public/ during a sloppy deploy.
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>
<Files "index.php">
    Require all granted
</Files>

# Static assets are immutable per release: the stylesheet is referenced with
# ?v={app_version} and images/icons change path or content with releases, so
# clients can cache them for a year. HTML responses are not matched here.
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|svg|ico|woff2?)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Frame-Options "DENY"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # HSTS only when the request actually came in over HTTPS — never on plain HTTP.
    # TLS terminates at the host's proxy, so %{HTTPS} is often unset; trust the
    # proxy's X-Forwarded-Proto as well, matching RequestContext::isHttps().
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on' || %{HTTP:X-Forwarded-Proto} == 'https'"

    # Content-Security-Policy. The high-value directives are locked down:
    # default-src 'self', object-src 'none' (no plugins), base-uri 'self' (no
    # <base> hijack), frame-ancestors 'none' (clickjacking — supersedes
    # X-Frame-Options on modern browsers). script/style still allow 'unsafe-inline'
    # because several templates embed inline <script>/<style>; tightening that to a
    # per-request nonce is the planned next step. Allowed origins are exactly what
    # the app loads: Google reCaptcha + Google Fonts.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.google.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-src https://www.google.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
</IfModule>

Options -Indexes
