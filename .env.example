# GPRO Pitwall configuration template.
# Copy to .env and fill in the blanks:  cp .env.example .env
# Generate random secrets with:         openssl rand -hex 32
#
# Values already set by the SAPI/shell take precedence over this file
# (immutable load — see src/Support/Env.php).

# ── App ──────────────────────────────────────────────────────────────────────
# true in local dev: emails land in var/mail/*.eml, reCAPTCHA is bypassed,
# exceptions are rethrown. MUST be false in prod.
IS_DEV=true

# REQUIRED. Root secret: HMAC key for email hashes + verification codes and
# the derivation root for the AES-256-GCM keys (email + API-token storage).
# Never reuse the dev value in prod.
APP_SECRET=

# Canonical origin for SEO tags (rel=canonical, og:url, og:image).
# Only set this when serving from a different domain (e.g. staging).
#APP_PUBLIC_URL=https://gpro-pitwall.com

# SQLite file, relative to the project root (kept outside docroot on the server).
#DB_FILE=gpro_pilots.sqlite

# ── Cache ────────────────────────────────────────────────────────────────────
# filesystem (default, zero infra) | apcu | redis | none
CACHE_DRIVER=filesystem
# Default TTL for per-user GPRO API payloads, seconds (3 days).
#CACHE_TTL_SHORT=259200
# Only used when CACHE_DRIVER=redis:
#REDIS_HOST=127.0.0.1
#REDIS_PORT=6379
#REDIS_PASSWORD=

# ── GPRO API ─────────────────────────────────────────────────────────────────
#GPRO_API_BASE_URL=https://gpro.net
# Per-call curl timeouts (seconds). Generous by default — GPRO can be slow under
# load; raise rather than lower if you see connection errors during sync.
#GPRO_API_CONNECT_TIMEOUT=10
#GPRO_API_TIMEOUT=30
#GPRO_API_MARKET_TIMEOUT=60
# Race-window cache epochs: race days (ISO weekday numbers), boundary hour, tz.
# Empty GPRO_RACE_DAYS disables windowing (plain TTL caching).
#GPRO_RACE_DAYS=2,5
#GPRO_RACE_BOUNDARY_HOUR=0
#GPRO_RACE_TZ=Europe/London
# Server-wide outbound throttle (all calls leave from one host IP). Token bucket
# shared across workers: GPRO_API_RATE calls/sec steady, GPRO_API_BURST back-to-back
# before pacing, GPRO_API_MAX_BLOCK_MS caps how long one call waits. Rate 0 disables.
#GPRO_API_RATE=2
#GPRO_API_BURST=4
#GPRO_API_MAX_BLOCK_MS=4000

# ── Mail (SMTP, prod only — dev writes .eml files instead) ──────────────────
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_ENCRYPTION=tls
MAIL_FROM=admin@gpro-pitwall.com
MAIL_FROM_NAME="GPRO Pitwall"

# ── reCAPTCHA (required in prod; bypassed when IS_DEV=true) ─────────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Auth & sync tuning (defaults shown) ──────────────────────────────────────
VERIFICATION_CODE_TTL_SECONDS=600
VERIFICATION_MAX_ATTEMPTS=5
# Per-account cap on emailed login codes per hour (anti-flood).
#MAX_CODES_PER_USER_PER_HOUR=3
# Skip the login-time auto-sync when the last sync is younger than this.
#SYNC_MIN_INTERVAL_SECONDS=600
# Defer syncing when apiRequestsRemaining < calls-needed + this margin.
#SYNC_SAFETY_MARGIN=20

# ── UI ───────────────────────────────────────────────────────────────────────
#PAGINATION_LIMIT=20
