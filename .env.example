# GPRO Driver Analyzer Environment Config

# Infrastructure
IS_DEV=true
DB_FILE="gpro_pilots.sqlite"
WRITE_DISABLED_MESSAGE="You don't have permissions to take this action"

# API & External Services
GPRO_API_BASE_URL="https://gpro.net"

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Security
APP_SECRET=some_long_random_string_here

# Mail
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_ENCRYPTION=null
MAIL_FROM=no-reply@gpro-assistant.com
MAIL_FROM_NAME="GPRO Assistant"

# Rate Limiting & Verification
VERIFICATION_CODE_TTL_SECONDS=600
VERIFICATION_MAX_ATTEMPTS=5
RATE_LIMIT_EMAIL_PER_HOUR=6
RATE_LIMIT_IP_PER_HOUR=20

# System
PAGINATION_LIMIT=20
CACHE_TTL_VERY_SHORT=3600
CACHE_TTL_SHORT=259200
CACHE_TTL_LONG=5184000
CACHE_DRIVER=apcu #apcu, redis, none
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

EMAIL_ENCRYPTION_KEY=