<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GPRO Driver Analyzer</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <style type="text/tailwindcss">
        @theme {
            --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
        }

        /* =========================
           BUTTON STANDARD
        ========================= */

        .btn {
            @apply inline-flex items-center justify-center gap-2
                   rounded-md font-semibold transition-all
                   focus:outline-none focus:ring-2 focus:ring-offset-2
                   disabled:opacity-50 disabled:cursor-not-allowed;
        }

        .btn-sm { @apply px-3 py-1.5 text-xs; }
        .btn-md { @apply px-4 py-2 text-sm; }
        .btn-lg { @apply px-5 py-3 text-sm; }

        .btn-primary {
            @apply bg-blue-600 text-white
                   hover:bg-blue-700
                   focus:ring-blue-500;
        }

        .btn-secondary {
            @apply bg-slate-200 text-slate-800
                   hover:bg-slate-300
                   focus:ring-slate-400;
        }

        .btn-danger {
            @apply bg-red-500 text-white
                   hover:bg-red-600
                   focus:ring-red-400;
        }

        .btn-disabled {
            @apply bg-slate-300 text-slate-500 cursor-not-allowed;
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>

<body class="h-full font-sans text-slate-800 antialiased">
<div class="min-h-full">

    {# HEADER #}
    <header class="bg-white shadow-sm border-b border-slate-200">
        <div class="mx-auto max-w-7xl px-4 py-6 flex justify-between items-center">
            <div>
                <h1 class="text-3xl font-bold text-slate-900">
                    <a href="/" class="hover:opacity-80">
                        <span class="text-blue-600">GPRO</span> Driver Analyzer
                    </a>
                </h1>
                <p class="mt-1 text-sm text-slate-500">
                    Optimize your team strategy and recruitment.
                </p>
            </div>

            <div class="flex items-center gap-4">
                {% if is_logged_in and user.is_admin %}
                    <a href="/debug"
                    class="btn btn-sm btn-secondary">
                        Debug
                    </a>
                {% endif %}
                {% if is_logged_in %}
                    <a href="/control_panel" class="text-sm font-medium text-slate-600 hover:text-blue-600">
                        Control Panel
                    </a>

                    <form method="POST" action="/logout">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        <button type="submit" class="btn btn-sm btn-danger">
                            Logout
                        </button>
                    </form>
                {% else %}
                    <a href="/login" class="text-sm font-medium text-slate-600 hover:text-blue-600">
                        Log In
                    </a>
                    <a href="/register" class="btn btn-md btn-primary">
                        Register
                    </a>
                {% endif %}
            </div>
        </div>
    </header>

    {% if can_submit %}
    <div class="bg-slate-50 border-b border-slate-200">
        <div class="mx-auto max-w-7xl px-4 py-2">
            <button
                id="apiWarmupBtn"
                class="btn btn-md btn-primary"
            >
                <svg id="apiWarmupSpinner" class="hidden h-4 w-4 animate-spin" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10"
                            stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor"
                          d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"/>
                </svg>
                <span id="apiWarmupText">Warm up API cache</span>
            </button>
        </div>
    </div>
    {% endif %}

    <main>
        <div class="mx-auto max-w-7xl py-6 px-4">
            {% block content %}{% endblock %}
        </div>
    </main>

    <footer class="py-6 text-center">
        <div class="inline-flex items-center gap-2 text-xs text-slate-400">
            <span>&copy; {{ "now"|date("Y") }} GPRO Assistant</span>
            <span class="opacity-50">•</span>
            <a
                href="https://github.com/MVinhas/gpro-assistant"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 font-medium text-slate-500
                    hover:text-blue-600 transition"
            >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" clip-rule="evenodd"
                        d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.1 3.29 9.43 7.86 10.96.57.1.78-.25.78-.55
                        0-.27-.01-.98-.02-1.93-3.2.7-3.88-1.55-3.88-1.55-.53-1.36-1.29-1.72-1.29-1.72
                        -1.05-.72.08-.71.08-.71 1.16.08 1.77 1.2 1.77 1.2
                        1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55
                        -2.56-.29-5.26-1.29-5.26-5.75 0-1.27.46-2.31 1.2-3.13
                        -.12-.3-.52-1.52.11-3.16 0 0 .97-.31 3.18 1.19
                        .92-.26 1.9-.39 2.88-.39.98 0 1.96.13 2.88.39
                        2.2-1.5 3.17-1.19 3.17-1.19.64 1.64.24 2.86.12 3.16
                        .75.82 1.2 1.86 1.2 3.13 0 4.47-2.7 5.45-5.28 5.74
                        .41.36.78 1.07.78 2.16 0 1.56-.01 2.82-.01 3.2
                        0 .3.2.66.79.55 4.56-1.53 7.85-5.86 7.85-10.96
                        C23.5 5.74 18.27.5 12 .5z"/>
                </svg>
                <span>View source on GitHub</span>
            </a>
        </div>
    </footer>
</div>

<script>
document.getElementById('apiWarmupBtn')?.addEventListener('click', async function () {
    const btn = this;
    const spinner = document.getElementById('apiWarmupSpinner');
    const text = document.getElementById('apiWarmupText');

    btn.disabled = true;
    spinner.classList.remove('hidden');
    text.textContent = 'Warming API cache...';

    try {
        const res = await fetch('/api/warmup', {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded'},
            body: new URLSearchParams({ csrf_token: '{{ csrf_token }}' })
        });
        const data = await res.json();
        text.textContent = data.success ? 'API cache ready ✔' : 'Warmup failed';
    } catch {
        text.textContent = 'Network error';
    }

    setTimeout(() => {
        btn.disabled = false;
        spinner.classList.add('hidden');
        text.textContent = 'Warm up API cache';
    }, 3000);
});
</script>

</body>
</html>
