{% import "partials/_localtime.twig" as t %}
<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {# Per-page SEO. Pages override these blocks; the defaults describe the
       homepage. Keep titles ≤ 60 chars (front-load the search keywords) and
       descriptions ≤ 160 chars. #}
    {% set default_title = 'GPRO Setup Calculator & Race Strategy Planner — GPRO Pitwall' %}
    {% set default_description = 'Free GPRO strategy tool: setup calculator, race strategy planner, car wear analysis, fuel & tyre forecasts, training planner and driver market analyzer for Grand Prix Racing Online.' %}
    <title>{% block title %}{{ default_title }}{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}{{ default_description }}{% endblock %}">
    {% block robots %}{% endblock %}
    <link rel="canonical" href="{{ canonical_host }}{% block canonical_path %}/{% endblock %}">
    <meta name="theme-color" content="#142f4d">

    <meta property="og:site_name" content="GPRO Pitwall">
    <meta property="og:title" content="{{ block('title') }}">
    <meta property="og:description" content="{{ block('meta_description') }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ canonical_host }}{{ block('canonical_path') }}">
    <meta property="og:image" content="{{ canonical_host }}/assets/og-image.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ block('title') }}">
    <meta name="twitter:description" content="{{ block('meta_description') }}">
    <meta name="twitter:image" content="{{ canonical_host }}/assets/og-image.png">

    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/logo.svg">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    {# Version query enables long-lived asset caching (see .htaccess) while
       guaranteeing every release busts the client cache. #}
    <link rel="stylesheet" href="/assets/app.css?v={{ app_version }}">
    {% block structured_data %}{% endblock %}
</head>

<body class="h-full font-sans text-slate-800 antialiased">
<div class="min-h-full">

    {# HEADER #}
    <header class="bg-white shadow-sm border-b border-slate-200">
        <div class="mx-auto max-w-7xl px-4 py-6 flex flex-col gap-4 md:flex-row md:justify-between md:items-center">
            <div>
                <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
                    <img src="/logo.svg" alt="" class="h-10 w-10 shrink-0" width="40" height="40">
                    <div>
                        <h1 class="text-3xl font-bold text-slate-900 leading-tight">
                            <span class="text-blue-600">GPRO</span> Pitwall
                        </h1>
                        <p class="mt-1 text-sm text-slate-500">
                            Race-weekend cockpit for GPRO managers — strategy, wear, training, recruitment.
                        </p>
                    </div>
                </a>
            </div>

            <div class="flex items-center gap-4 flex-wrap">
                {% if is_logged_in and api_limit is defined and api_limit != '?' %}
                    {% set api_tone = (api_limit < 20) ? 'bg-red-50 text-red-700 ring-red-600/20'
                                      : ((api_limit < 50) ? 'bg-amber-50 text-amber-700 ring-amber-600/20'
                                                          : 'bg-slate-50 text-slate-700 ring-slate-600/10') %}
                    {% set api_age = api_limit_updated_at
                        ? ' · checked ' ~ ((('now'|date('U')) - api_limit_updated_at) // 60) ~ 'm ago'
                        : '' %}
                    {% set api_tip = (api_limit < 50)
                        ? 'Few API calls left this race weekend — avoid hard-refreshing data; the cache keeps recent answers warm for you.' ~ api_age
                        : 'GPRO API calls remaining for this race.' ~ api_age %}
                    <span class="inline-flex items-center" data-api-budget-wrap>
                        <span
                            class="inline-flex items-center gap-1.5 rounded-l-md px-2.5 py-1 text-xs font-medium ring-1 ring-inset tabular-nums cursor-help {{ api_tone }}"
                            title="{{ api_tip }}"
                            data-api-budget-pill
                        >
                            {% if api_limit < 50 %}<span aria-hidden="true">⚠</span>{% endif %}
                            <span class="text-slate-400">API</span>
                            <span class="font-semibold" data-api-budget-value>{{ api_limit|number_format }}</span>
                            <span class="text-slate-400">left</span>
                        </span>
                        <button
                            type="button"
                            class="-ml-px inline-flex items-center px-1.5 py-1 rounded-r-md text-xs ring-1 ring-inset hover:bg-slate-100 cursor-pointer {{ api_tone }}"
                            title="Refresh the counter (costs 1 API call)"
                            data-api-budget-refresh
                            aria-label="Refresh API budget counter"
                        >
                            <span aria-hidden="true">↻</span>
                        </button>
                    </span>
                {% endif %}
                {% if is_logged_in and user.is_admin %}
                    <a href="/admin/users" class="btn btn-sm btn-secondary">Users</a>
                    <a href="/debug" class="btn btn-sm btn-secondary">Debug</a>
                {% endif %}
                {% if is_logged_in %}
                    <a href="/control_panel"
                       class="btn btn-sm font-medium text-slate-600 hover:text-blue-600">
                        Control Panel
                    </a>

                    <form method="POST" action="/logout">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        <button type="submit" class="btn btn-sm btn-danger">
                            Logout
                        </button>
                    </form>
                {% else %}
                    <a href="/login" class="text-sm font-medium text-slate-600 hover:text-blue-600">
                        Log In
                    </a>
                    <a href="/register" class="btn btn-md btn-primary">
                        Register
                    </a>
                {% endif %}
            </div>
        </div>
    </header>
    {% if is_logged_in %}
    <div class="bg-slate-50 border-b border-slate-200">
        <div class="mx-auto max-w-7xl px-4 py-2 text-sm text-slate-600 flex flex-wrap items-center justify-between gap-x-4 gap-y-2">
            <div class="flex items-center gap-3">
                {% set has_status = user.sync_status in ['running', 'failed', 'deferred_low_budget'] or user.last_synced_at %}
                {% if user.username %}
                    <span class="font-medium text-slate-700">Hello, {{ user.username }}</span>
                    {% if has_status %}<span class="text-slate-300" aria-hidden="true">|</span>{% endif %}
                {% endif %}
                {% if user.sync_status == 'running' %}
                    <span class="animate-spin">⏳</span>
                    <span>Syncing GPRO data…</span>
                {% elseif user.sync_status == 'failed' %}
                    <span class="text-red-600">⚠ Sync failed</span>
                {% elseif user.sync_status == 'deferred_low_budget' %}
                    <span class="text-amber-600">⏸ Sync paused — GPRO API budget low. It'll resume once your hourly allowance recovers.</span>
                {% elseif user.last_synced_at %}
                    <span>Last sync: {{ t.localtime(user.last_synced_at, 'datetime') }}</span>
                {% endif %}
            </div>

            {% if billboard %}
            <div class="flex items-center divide-x divide-slate-300 text-xs font-medium tabular-nums">
                <span class="px-3 first:pl-0">
                    <span class="text-slate-400">Cash</span>
                    <span class="ml-1 text-slate-700">${{ billboard.cash|number_format(0, '.', ',') }}</span>
                </span>
                {% if billboard.division %}
                <span class="px-3">
                    <span class="text-slate-400">Division</span>
                    <span class="ml-1 text-slate-700">{{ billboard.division }}</span>
                </span>
                {% endif %}
                {% if billboard.next_track %}
                <span class="px-3 last:pr-0">
                    <span class="text-slate-400">⏭ Next</span>
                    <span class="ml-1 text-slate-700">{{ billboard.next_track }}</span>
                    {% if billboard.season and billboard.race %}
                        <span class="ml-1 text-slate-400">S{{ billboard.season }} R{{ billboard.race }}</span>
                    {% endif %}
                </span>
                {% endif %}
            </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {% if can_submit %}
    <div class="bg-slate-50 border-b border-slate-200">
        <div class="mx-auto max-w-7xl px-4 py-2">
            <button
                id="apiWarmupBtn"
                class="btn btn-md btn-primary"
            >
                <svg id="apiWarmupSpinner" class="hidden h-4 w-4 animate-spin" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10"
                            stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor"
                          d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"/>
                </svg>
                <span id="apiWarmupText">Re-sync your data</span>
            </button>
        </div>
    </div>
    {% endif %}

    <main>
        <div class="mx-auto max-w-7xl py-6 px-4">
            {% block content %}{% endblock %}
        </div>
    </main>

    <footer class="px-4 py-6">
        <div class="mx-auto flex max-w-7xl flex-col items-center gap-2 text-xs text-slate-400">
            <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-2">
                <span>&copy; {{ "now"|date("Y") }} GPRO Pitwall {{ app_version }}</span>
                <span class="opacity-50" aria-hidden="true">•</span>
                <span class="inline-flex items-center gap-1.5 text-slate-500">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" clip-rule="evenodd"
                            d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.1 3.29 9.43 7.86 10.96.57.1.78-.25.78-.55
                            0-.27-.01-.98-.02-1.93-3.2.7-3.88-1.55-3.88-1.55-.53-1.36-1.29-1.72-1.29-1.72
                            -1.05-.72.08-.71.08-.71 1.16.08 1.77 1.2 1.77 1.2
                            1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55
                            -2.56-.29-5.26-1.29-5.26-5.75 0-1.27.46-2.31 1.2-3.13
                            -.12-.3-.52-1.52.11-3.16 0 0 .97-.31 3.18 1.19
                            .92-.26 1.9-.39 2.88-.39.98 0 1.96.13 2.88.39
                            2.2-1.5 3.17-1.19 3.17-1.19.64 1.64.24 2.86.12 3.16
                            .75.82 1.2 1.86 1.2 3.13 0 4.47-2.7 5.45-5.28 5.74
                            .41.36.78 1.07.78 2.16 0 1.56-.01 2.82-.01 3.2
                            0 .3.2.66.79.55 4.56-1.53 7.85-5.86 7.85-10.96
                            C23.5 5.74 18.27.5 12 .5z"/>
                    </svg>
                    <a
                        href="https://github.com/MVinhas/gpro-pitwall"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="font-medium hover:text-blue-600 transition"
                    >View source</a>
                    <span class="opacity-50" aria-hidden="true">·</span>
                    <a
                        href="https://github.com/MVinhas/gpro-pitwall/issues"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="font-medium hover:text-blue-600 transition"
                    >Open GitHub Issue</a>
                </span>
                <span class="opacity-50" aria-hidden="true">•</span>
                {% if is_logged_in %}
                <a
                    href="/contact"
                    class="inline-flex items-center gap-1 font-medium text-slate-500
                        hover:text-blue-600 transition"
                >Send feedback</a>
                {% else %}
                <a
                    href="mailto:admin@gpro-pitwall.com"
                    class="inline-flex items-center gap-1 font-medium text-slate-500
                        hover:text-blue-600 transition"
                >Contact me</a>
                {% endif %}
                <span class="opacity-50" aria-hidden="true">•</span>
                <a
                    href="https://buymeacoffee.com/mvinhas"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 font-medium text-amber-600
                        hover:text-amber-700 transition"
                    title="If Pitwall saved your race weekend, buy me a coffee"
                >
                    <span aria-hidden="true">☕</span>
                    <span>Buy me a coffee</span>
                </a>
            </div>
            <p class="max-w-prose text-center text-slate-400">
                GPRO Pitwall is an unofficial fan tool, not affiliated with or endorsed by
                <a
                    href="https://www.gpro.net"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-medium text-slate-500 hover:text-blue-600 transition"
                >Grand Prix Racing Online</a>.
            </p>
        </div>
    </footer>
</div>

{# API budget refresh confirmation modal — opens when the ↻ next to the
   budget badge is clicked. Explicit so the user understands the cost. #}
{% if is_logged_in and api_limit is defined and api_limit != '?' %}
<div
    id="apiBudgetModal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40"
    role="dialog"
    aria-modal="true"
    aria-labelledby="apiBudgetModalTitle"
>
    <div class="bg-white rounded-xl shadow-xl border border-slate-200 max-w-sm w-full mx-4 p-5">
        <h2 id="apiBudgetModalTitle" class="t-heading mb-2">Refresh the API counter?</h2>
        <p class="t-caption mb-3">
            Reading the real current value from GPRO <strong>costs 1 API call</strong>.
            There is no free way to query it.
        </p>
        <p class="t-caption mb-4">
            {% if user.last_synced_at %}
                Your last data sync was
                <strong>{{ t.localtime(user.last_synced_at, 'datetime') }}</strong>.
            {% else %}
                You haven't synced any data yet.
            {% endif %}
            Each sync uses API calls, so the counter may be lower than shown.
            Unless you've re-synced and are close to the limit, you can skip the refresh.
        </p>
        <div class="flex justify-end gap-2">
            <button type="button" class="btn btn-md btn-secondary" data-api-budget-cancel>Cancel</button>
            <button type="button" class="btn btn-md btn-primary" data-api-budget-confirm data-busy-text="Refreshing…">
                Refresh now (1 call)
            </button>
        </div>
    </div>
</div>
{% endif %}

<script>
// API-budget refresh modal: explicit click → confirm → 1 API call.
(() => {
    const refreshBtn = document.querySelector('[data-api-budget-refresh]');
    const modal = document.getElementById('apiBudgetModal');
    if (!refreshBtn || !modal) return;
    const cancelBtn = modal.querySelector('[data-api-budget-cancel]');
    const confirmBtn = modal.querySelector('[data-api-budget-confirm]');
    const valueEl = document.querySelector('[data-api-budget-value]');
    const csrf = '{{ csrf_token }}';

    function open() {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }
    function close() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }

    refreshBtn.addEventListener('click', open);
    cancelBtn.addEventListener('click', close);
    modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.classList.contains('hidden')) close(); });

    confirmBtn.addEventListener('click', async () => {
        const original = confirmBtn.textContent;
        confirmBtn.disabled = true;
        confirmBtn.textContent = confirmBtn.dataset.busyText || 'Refreshing…';
        try {
            const res = await fetch('/api/refresh_budget', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: new URLSearchParams({ csrf_token: csrf })
            });
            const data = await res.json();
            if (data.success && typeof data.remaining === 'number') {
                if (valueEl) valueEl.textContent = data.remaining.toLocaleString();
            }
        } catch (_) {
            // Network error — leave the badge as-is; the next page load will update.
        } finally {
            confirmBtn.disabled = false;
            confirmBtn.textContent = original;
            close();
        }
    });
})();
</script>

<script>
document.getElementById('apiWarmupBtn')?.addEventListener('click', async function () {
    const btn = this;
    const spinner = document.getElementById('apiWarmupSpinner');
    const text = document.getElementById('apiWarmupText');

    btn.disabled = true;
    spinner.classList.remove('hidden');
    text.textContent = 'Re-syncing...';

    try {
        const res = await fetch('/api/warmup', {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded'},
            body: new URLSearchParams({ csrf_token: '{{ csrf_token }}' })
        });
        const data = await res.json();
        text.textContent = (data.success ? '✔ ' : '⚠ ') + (data.message || 'Done');
        // Reload so the freshly-synced data shows on the current tab.
        if (data.status === 'synced') {
            setTimeout(() => window.location.reload(), 800);
        }
    } catch {
        text.textContent = '⚠ Network error';
    }

    setTimeout(() => {
        btn.disabled = false;
        spinner.classList.add('hidden');
        text.textContent = 'Re-sync your data';
    }, 3000);
});

// Single-submit guard: any form tagged data-disable-on-submit disables every
// submit button inside it the moment the form is submitted. Prevents the
// double-click problem on slow endpoints (verify, register, login_request).
document.addEventListener('submit', (e) => {
    const form = e.target;
    if (!(form instanceof HTMLFormElement)) return;
    if (!form.hasAttribute('data-disable-on-submit')) return;
    form.querySelectorAll('button[type="submit"], input[type="submit"]').forEach((btn) => {
        btn.disabled = true;
        btn.classList.add('opacity-60', 'cursor-not-allowed');
        const busyText = btn.dataset.busyText;
        if (busyText && btn.tagName === 'BUTTON') {
            btn.textContent = busyText;
        }
    });
}, true);
</script>

<script>
// Local-time rendering: timestamps are stored and emitted as UTC. Rewrite every
// <time data-localtime> into the visitor's own timezone via Intl, so a user in
// any zone sees their local time. No-JS users keep the server-rendered UTC text.
(() => {
    const PRESETS = {
        datetime: { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' },
        date:     { month: 'short', day: 'numeric', year: 'numeric' },
        day:      { month: 'short', day: 'numeric' },
    };
    document.querySelectorAll('time[data-localtime]').forEach((el) => {
        const iso = el.getAttribute('datetime');
        if (!iso) return;
        const d = new Date(iso);
        if (isNaN(d)) return;
        const opts = PRESETS[el.dataset.localtime] || PRESETS.datetime;
        try {
            el.textContent = new Intl.DateTimeFormat(undefined, opts).format(d);
        } catch (_) {
            // Leave the UTC fallback in place if Intl formatting fails.
        }
    });
})();
</script>

</body>
</html>
