{% extends "layout.twig" %}

{% block title %}Verify your code — GPRO Pitwall{% endblock %}
{% block robots %}<meta name="robots" content="noindex,nofollow">{% endblock %}
{% block canonical_path %}/verify{% endblock %}

{% block content %}
<div class="max-w-md mx-auto mt-10">

    <h1 class="t-display mb-4">Check your email</h1>

    {% if flash %}
        <div class="notice notice-warn mb-4">
            {{ flash }}
        </div>
    {% endif %}

    {# ============================
       SYNC FEEDBACK (AFTER VERIFY)
       ============================ #}
    {% if sync_status is defined and sync_status == 'running' %}
        <div class="notice notice-info mb-4 flex items-center gap-2">
            <span class="animate-spin">⏳</span>
            <span>Syncing your profile data from GPRO…</span>
        </div>
    {% elseif sync_status is defined and sync_status == 'failed' %}
        <div class="notice notice-error mb-4">
            GPRO sync failed. You can still continue and retry later.
        </div>
    {% endif %}

    <div class="card p-6">
        <p class="text-slate-600 mb-6 text-sm">
            We've sent a 6-digit verification code to your email address.
            Enter it below to continue.
        </p>

        <form method="POST" action="/login_verify" class="space-y-4" data-disable-on-submit>
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <label class="block">
                <span class="text-sm font-medium text-slate-700">
                    Verification Code
                </span>
                <input
                    required
                    type="text"
                    name="code"
                    maxlength="6"
                    autocomplete="one-time-code"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    placeholder="123456"
                    class="form-input mt-1 font-mono text-center text-2xl tracking-widest py-3"
                    {% if sync_status is defined and sync_status == 'running' %}
                        disabled
                    {% endif %}
                >
            </label>

            {# ============================
               SUBMIT BUTTON STATES
               ============================ #}
            {% if sync_status is defined and sync_status == 'running' %}
                <button
                    type="button"
                    disabled
                    class="btn btn-md btn-disabled w-full"
                >
                    <span class="animate-spin">⏳</span>
                    Syncing your profile data…
                </button>
            {% else %}
                <button
                    type="submit"
                    data-busy-text="Verifying…"
                    class="btn btn-md btn-primary w-full"
                >
                    Verify
                </button>
            {% endif %}
        </form>

        <div class="mt-6 text-center space-y-2">
            <form method="POST" action="/resend_code" data-disable-on-submit>
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <button type="submit" data-busy-text="Sending…"
                        class="text-xs text-blue-600 hover:underline">
                    Didn't get the code? Resend it
                </button>
            </form>
            <a href="/login" class="block text-xs text-slate-400 hover:text-slate-600">
                Start over / Use different account
            </a>
        </div>
    </div>
</div>
{% endblock %}
