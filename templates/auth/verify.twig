{% extends "layout.twig" %}

{% block content %}
<div class="max-w-md mx-auto mt-10">

    <h1 class="text-2xl font-bold mb-4">Check your email</h1>

    {% if flash %}
        <div class="bg-yellow-100 border border-yellow-200 text-yellow-800 p-3 rounded mb-4 text-sm">
            {{ flash }}
        </div>
    {% endif %}

    {# ============================
       SYNC FEEDBACK (AFTER VERIFY)
       ============================ #}
    {% if sync_status is defined and sync_status == 'running' %}
        <div class="mb-4 bg-blue-50 border border-blue-200 text-blue-800 p-3 rounded text-sm flex items-center gap-2">
            <span class="animate-spin">⏳</span>
            <span>Syncing your profile data from GPRO…</span>
        </div>
    {% elseif sync_status is defined and sync_status == 'failed' %}
        <div class="mb-4 bg-red-50 border border-red-200 text-red-800 p-3 rounded text-sm">
            GPRO sync failed. You can still continue and retry later.
        </div>
    {% endif %}

    <div class="bg-white p-6 rounded shadow-sm border border-slate-200">
        <p class="text-slate-600 mb-6 text-sm">
            We've sent a 6-digit verification code to your email address.
            Enter it below to continue.
        </p>

        <form method="POST" action="/login_verify" class="space-y-4">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <label class="block">
                <span class="text-sm font-medium text-slate-700">
                    Verification Code
                </span>
                <input
                    required
                    type="text"
                    name="code"
                    maxlength="6"
                    autocomplete="one-time-code"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    placeholder="123456"
                    class="form-input mt-1 font-mono text-center text-2xl tracking-widest py-3"
                    {% if sync_status is defined and sync_status == 'running' %}
                        disabled
                    {% endif %}
                >
            </label>

            {# ============================
               SUBMIT BUTTON STATES
               ============================ #}
            {% if sync_status is defined and sync_status == 'running' %}
                <button
                    type="button"
                    disabled
                    class="w-full px-4 py-2 rounded bg-slate-300 text-slate-500
                           font-medium cursor-not-allowed flex items-center
                           justify-center gap-2"
                >
                    <span class="animate-spin">⏳</span>
                    Syncing your profile data…
                </button>
            {% else %}
                <button
                    type="submit"
                    class="w-full px-4 py-2 rounded bg-blue-600 hover:bg-blue-700
                           text-white font-medium transition-colors"
                >
                    Verify
                </button>
            {% endif %}
        </form>

        <div class="mt-6 text-center">
            <a href="/login" class="text-xs text-slate-400 hover:text-slate-600">
                Start over / Use different account
            </a>
        </div>
    </div>
</div>
{% endblock %}
