{% extends "layout.twig" %}

{% block content %}
<div class="max-w-md mx-auto mt-10">
    <h1 class="text-2xl font-bold mb-4">Sign in</h1>
    
    {% if flash %}
        <div class="bg-yellow-100 border border-yellow-200 text-yellow-800 p-3 rounded mb-4 text-sm">{{ flash }}</div>
    {% endif %}

    <form method="POST" action="/login_request" data-disable-on-submit class="space-y-4 bg-white p-6 rounded shadow-sm border border-slate-200">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

        <label class="block">
            <span class="text-sm font-medium text-slate-700">Username</span>
            <input required type="text" name="username" class="form-input mt-1">
        </label>

        <label class="flex items-center gap-2 text-sm text-slate-700">
            <input type="checkbox" name="remember" value="1" class="rounded border-slate-300">
            Keep me signed in
        </label>

        {# reCAPTCHA — makes blind username-guessing non-automatable, so the
           login form can't be scripted to ping real users by email. #}
        {% if recaptcha_site_key %}
            <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
        {% endif %}

        <button type="submit" data-busy-text="Sending code…" class="w-full px-4 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white font-medium transition-colors">
            Continue
        </button>

        <div class="text-center text-sm text-slate-500 mt-4">
            Don't have an account? <a href="/register" class="text-blue-600 hover:underline">Register</a>
        </div>
    </form>
</div>

{% if recaptcha_site_key %}
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
{% endif %}
{% endblock %}