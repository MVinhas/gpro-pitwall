{% extends "layout.twig" %}

{% block title %}Log in — GPRO Pitwall{% endblock %}
{% block meta_description %}Log in to GPRO Pitwall, the free race strategy, setup calculator and car wear tool for Grand Prix Racing Online managers.{% endblock %}
{% block canonical_path %}/login{% endblock %}

{% block content %}
<div class="max-w-md mx-auto mt-10">
    <h1 class="t-display mb-4">Sign in</h1>

    {% if flash %}
        <div class="notice notice-warn mb-4">{{ flash }}</div>
    {% endif %}

    <form method="POST" action="/login_request" data-disable-on-submit class="card p-6 space-y-4">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

        <label class="block">
            <span class="text-sm font-medium text-slate-700">Username</span>
            <input required type="text" name="username" id="login-username" autocomplete="username" class="form-input mt-1">
        </label>

        <label class="flex items-center gap-2 text-sm text-slate-700">
            <input type="checkbox" name="remember" value="1" class="rounded border-slate-300">
            Keep me signed in
        </label>

        {# reCAPTCHA — makes blind username-guessing non-automatable, so the
           login form can't be scripted to ping real users by email. #}
        {% if recaptcha_site_key %}
            <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
        {% endif %}

        <button type="submit" data-busy-text="Sending code…" class="btn btn-md btn-primary w-full">
            Continue
        </button>

        <div class="text-center text-sm text-slate-500 mt-4">
            Don't have an account? <a href="/register" class="text-blue-600 hover:underline">Register</a>
        </div>
    </form>
</div>

{% if recaptcha_site_key %}
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
{% endif %}

<script>
// Remember the last username on this browser so returning users (who rely on
// persistent login tokens and may forget their username) don't have to recall it.
// Low-sensitivity value, same-origin only; no server state.
(() => {
    const KEY = 'gpro.lastUsername';
    const input = document.getElementById('login-username');
    if (!input) return;
    try {
        if (!input.value) {
            const saved = localStorage.getItem(KEY);
            if (saved) input.value = saved;
        }
    } catch (_) { /* storage blocked — skip prefill */ }
    input.form?.addEventListener('submit', () => {
        try {
            const v = input.value.trim();
            if (v) localStorage.setItem(KEY, v);
        } catch (_) { /* storage blocked — nothing to persist */ }
    });
})();
</script>
{% endblock %}