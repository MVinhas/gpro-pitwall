{% extends "layout.twig" %}

{% block title %}Confirm it's you — GPRO Pitwall{% endblock %}
{% block robots %}<meta name="robots" content="noindex,nofollow">{% endblock %}
{% block canonical_path %}/reauth{% endblock %}

{% block content %}
<div class="max-w-md mx-auto mt-10">

    <h1 class="t-display mb-4">Confirm it's you</h1>

    {% if flash %}
        <div class="notice notice-warn mb-4">
            {{ flash }}
        </div>
    {% endif %}

    <div class="notice notice-info mb-4">
        <strong>Extra check.</strong> This action is sensitive, so we need a fresh code to confirm it's really you.
    </div>

    <div class="card p-6">
        <p class="text-slate-600 mb-6 text-sm">
            We've sent a 6-digit code to your email address. Enter it to continue.
        </p>

        <form method="POST" action="/reauth_verify" class="space-y-4" data-disable-on-submit>
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <label class="block">
                <span class="text-sm font-medium text-slate-700">Verification Code</span>
                <input
                    required
                    type="text"
                    name="code"
                    maxlength="6"
                    autocomplete="one-time-code"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    placeholder="123456"
                    class="form-input mt-1 font-mono text-center text-2xl tracking-widest py-3"
                >
            </label>

            <button
                type="submit"
                data-busy-text="Verifying…"
                class="btn btn-md btn-primary w-full"
            >
                Confirm
            </button>
        </form>

        <div class="mt-6 text-center">
            <a href="/control_panel" class="text-xs text-slate-400 hover:text-slate-600">
                Cancel
            </a>
        </div>
    </div>
</div>
{% endblock %}
