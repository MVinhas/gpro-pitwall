{% extends "layout.twig" %}

{% block content %}
<div class="max-w-md mx-auto mt-10">
    <h1 class="t-display mb-4">Create Account</h1>

    {% if flash %}
        <div class="notice notice-warn mb-4">{{ flash }}</div>
    {% endif %}

    <form method="POST" action="/register_request" id="regForm" data-disable-on-submit class="space-y-4 bg-white p-6 rounded shadow-sm border border-slate-200">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

        {# Username #}
        <label class="block">
            <span class="text-sm font-medium text-slate-700">Username</span>
            <input required type="text" name="username" pattern="[A-Za-z0-9_]{3,20}" title="3-20 characters: letters, numbers, underscore" class="form-input mt-1">
            <span class="text-xs text-slate-500">3-20 characters. <strong class="text-slate-600">This is your login</strong> — your email can't sign you in. Pick something memorable.</span>
        </label>

        {# Email #}
        <label class="block">
            <span class="text-sm font-medium text-slate-700">Email Address</span>
            <input required type="email" name="email" class="form-input mt-1">
            <span class="text-xs text-slate-500">We'll send a code to verify this.</span>
        </label>

        {# reCAPTCHA Enterprise Challenge (checkbox) — Google's JS fills the
           hidden g-recaptcha-response field automatically when the user passes. #}
        {% if recaptcha_site_key %}
            <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
        {% endif %}

        <button type="submit" data-busy-text="Creating account…" class="btn btn-md btn-primary w-full">
            Sign Up
        </button>

        <div class="text-center text-sm text-slate-500 mt-4">
            Already have an account? <a href="/login" class="text-blue-600 hover:underline">Log in</a>
        </div>
    </form>

    <div class="text-xs text-center text-slate-400 mt-6">
        This site is protected by reCAPTCHA and the Google
        <a href="https://policies.google.com/privacy" class="underline">Privacy Policy</a> and
        <a href="https://policies.google.com/terms" class="underline">Terms of Service</a> apply.
    </div>
</div>

{% if recaptcha_site_key %}
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
{% endif %}
{% endblock %}