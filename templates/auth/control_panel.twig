{% extends "layout.twig" %}

{% block content %}
<div class="max-w-2xl mx-auto mt-10">
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-8">
        
        <div class="border-b border-slate-100 pb-6 mb-6 flex justify-between items-center">
            <div>
                <h1 class="text-2xl font-bold text-slate-800">Control Panel</h1>
                <p class="text-slate-500 mt-1">Manage your account settings</p>
            </div>
            <div class="text-right">
                <span class="block text-sm text-slate-400 uppercase tracking-wider font-semibold">Account Status</span>
                {% if user.is_premium %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-amber-50 px-3 py-1 text-sm font-medium text-amber-700 ring-1 ring-inset ring-amber-600/20">
                        Premium
                    </span>
                {% else %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-600 ring-1 ring-inset ring-slate-500/10">
                        Free User
                    </span>
                {% endif %}
            </div>
        </div>

        {% if flash %}
            <div class="bg-blue-50 border border-blue-200 text-blue-700 p-4 rounded mb-6 text-sm">
                {{ flash }}
            </div>
        {% endif %}

        {# API Token Form #}
        <div class="mb-8">
            <h2 class="text-lg font-semibold text-slate-800 mb-4">GPRO API Connection</h2>
            
            {% if not user.is_premium %}
                <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-4">
                    <p class="text-sm text-yellow-700">
                        <strong>Note:</strong> You must be a Premium user to use API features. 
                        Contact support to upgrade.
                    </p>
                </div>
            {% endif %}

            <form method="POST" action="/update_token" class="space-y-4">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Your API Token</label>
                    <input type="text" 
                           name="api_token" 
                           value="{{ user.api_token }}" 
                           placeholder="eyJ0eXAiOiJKV1QiLCAiYW..."
                           class="block w-full rounded-md border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 font-mono text-sm"
                           {{ not user.is_premium ? 'disabled' : '' }}
                    >
                    <p class="mt-2 text-xs text-slate-500">
                        Found in your GPRO driver profile settings. Keep this secret.
                    </p>
                </div>

                <div class="flex justify-end">
                    <button type="submit" 
                            class="px-4 py-2 bg-blue-600 text-white rounded-md text-sm font-medium hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed"
                            {{ not user.is_premium ? 'disabled' : '' }}>
                        Save Token
                    </button>
                </div>
            </form>
        </div>

        {# Account Details (Read Only) #}
        <div class="border-t border-slate-100 pt-6">
            <h2 class="text-lg font-semibold text-slate-800 mb-4">Profile Info</h2>
            <div class="grid grid-cols-2 gap-4 text-sm">
                <div>
                    <span class="block text-slate-500">Username</span>
                    <span class="font-medium">{{ user.username }}</span>
                </div>
                <div>
                    <span class="block text-slate-500">Email</span>
                    <span class="font-medium">{{ user.email }}</span>
                </div>
                <div>
                    <span class="block text-slate-500">Member Since</span>
                    <span class="font-medium">{{ user.created_at|date("M j, Y") }}</span>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}