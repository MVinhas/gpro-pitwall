{% extends "layout.twig" %}
{% import "partials/_localtime.twig" as t %}

{% block content %}
<div class="max-w-2xl mx-auto mt-10">
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-8">

        <div class="border-b border-slate-100 pb-6 mb-6 flex justify-between items-center">
            <div>
                <h1 class="t-display">Control Panel</h1>
                <p class="t-caption mt-1">Manage your account settings</p>
            </div>
            {% if user.is_admin %}
                <span class="inline-flex items-center gap-1 rounded-full bg-blue-50 px-3 py-1 text-sm font-medium text-blue-700 ring-1 ring-inset ring-blue-600/20">
                    Admin
                </span>
            {% endif %}
        </div>

        {% if flash %}
            <div class="rounded-md bg-blue-50 border-l-4 border-blue-400 p-4 shadow-sm mb-6">
                <p class="text-sm text-blue-800">{{ flash }}</p>
            </div>
        {% endif %}
        {% if flash_error %}
            <div class="rounded-md bg-red-50 border-l-4 border-red-400 p-4 shadow-sm mb-6">
                <p class="text-sm text-red-800">{{ flash_error }}</p>
            </div>
        {% endif %}

        {# Orientation: tells the user where to go. Changes with token state. #}
        {% if has_token %}
            <div class="rounded-md bg-emerald-50 border-l-4 border-emerald-400 p-4 shadow-sm mb-8">
                <p class="text-sm font-bold text-emerald-800">You're connected.</p>
                <p class="text-sm text-emerald-800 mt-1">
                    Your data is syncing from GPRO. Head to the cockpit to plan
                    your race weekend — strategy, car wear, training and recruitment
                    are all in the top navigation.
                </p>
                <div class="mt-3">
                    <a href="/?main_tab=Cockpit" class="btn btn-md btn-primary">
                        Go to Race Weekend Cockpit →
                    </a>
                </div>
            </div>
        {% else %}
            <div class="rounded-md bg-amber-50 border-l-4 border-amber-400 p-4 shadow-sm mb-8">
                <p class="text-sm font-bold text-amber-800">One step left: add your API token.</p>
                <p class="text-sm text-amber-800 mt-1">
                    Paste your GPRO API token below to unlock the cockpit and every
                    analysis tool. It takes a few seconds.
                </p>
            </div>
        {% endif %}

        {# API Token Form #}
        <div class="mb-8">
            <h2 class="t-heading mb-4">GPRO API Connection</h2>

            <form method="POST" action="/update_token" class="space-y-4">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                <div>
                    <label class="t-label block mb-1">
                        {{ has_token ? 'Replace API Token' : 'Your API Token' }}
                    </label>
                    {% if has_token %}
                        <p class="mb-2 inline-flex items-center gap-1.5 rounded-md bg-emerald-50 px-2 py-1 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                            <span aria-hidden="true">●</span>
                            Token saved — ending <span class="font-mono">…{{ token_hint }}</span>
                        </p>
                    {% endif %}
                    <input type="text"
                           name="api_token"
                           value=""
                           autocomplete="off"
                           spellcheck="false"
                           placeholder="{{ has_token ? 'Paste a new token to replace it' : 'eyJ0eXAiOiJKV1QiLCAiYW...' }}"
                           class="form-input font-mono">
                    <p class="mt-2 text-xs text-slate-500">
                        1. Go to <a href="https://app.gpro.net/apiaccess" target="_blank" rel="noopener noreferrer" class="text-blue-600 underline">app.gpro.net/apiaccess</a><br>
                        2. Generate a new API token if you don't have one<br>
                        3. Copy the token and paste it here
                        {% if has_token %}<br>{% endif %}
                        {% if has_token %}<span class="text-slate-400">Leave blank to keep your current token.</span>{% endif %}
                    </p>
                </div>

                <div class="flex justify-end">
                    <button type="submit" class="btn btn-md btn-primary">
                        Save Token
                    </button>
                </div>
            </form>
        </div>

        {# Account Details (Read Only) #}
        <div class="border-t border-slate-100 pt-6">
            <h2 class="t-heading mb-4">Profile Info</h2>
            <div class="grid grid-cols-2 gap-4 text-sm">
                <div>
                    <span class="block text-slate-500">Username</span>
                    <span class="font-medium">{{ user.username }}</span>
                </div>
                <div>
                    <span class="block text-slate-500">Member Since</span>
                    <span class="font-medium">{{ t.localtime(user.created_at, 'date') }}</span>
                </div>
            </div>
        </div>

        {# Help #}
        <div class="border-t border-slate-100 pt-6 mt-6">
            <p class="text-xs text-slate-500">
                Need help with your account? Contact us at
                <a href="mailto:admin@gpro-pitwall.com" class="text-blue-600 underline">admin@gpro-pitwall.com</a>.
            </p>
        </div>

        {# Danger zone — intentionally low-prominence, at the very bottom. #}
        <details class="border-t border-slate-100 pt-6 mt-6 group">
            <summary class="text-xs font-medium text-slate-500 cursor-pointer hover:text-red-600 transition-colors list-none">
                <span class="inline-flex items-center gap-1">
                    <span class="text-slate-400 group-open:rotate-90 transition-transform">▸</span>
                    Delete my account
                </span>
            </summary>
            <div class="mt-4 rounded-md border border-red-200 bg-red-50 p-4">
                <p class="text-sm text-red-800">
                    This deactivates your account and logs you out. You won't be able
                    to log back in. This cannot be undone by you — contact an admin to
                    restore it.
                </p>
                <button type="button"
                        class="btn btn-sm btn-danger mt-3"
                        data-delete-account-open>
                    Delete account…
                </button>
            </div>
        </details>
    </div>
</div>

{# Delete confirmation modal: must type exact username to enable the button. #}
<div data-delete-account-modal
     class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40"
     role="dialog" aria-modal="true" aria-labelledby="deleteAccountTitle">
    <div class="bg-white rounded-xl shadow-xl border border-slate-200 max-w-sm w-full mx-4 p-5">
        <h2 id="deleteAccountTitle" class="t-heading mb-2">Delete your account?</h2>
        <p class="t-caption mb-4">
            This cannot be undone. To confirm, type your username
            <strong class="text-slate-700">{{ user.username }}</strong> below.
        </p>
        <form method="POST" action="/account/delete">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <input type="text"
                   name="confirm_username"
                   autocomplete="off"
                   placeholder="Type your username"
                   class="form-input"
                   data-delete-account-input
                   data-expected="{{ user.username }}">
            <div class="flex justify-end gap-2 mt-4">
                <button type="button" class="btn btn-md btn-secondary" data-delete-account-cancel>Cancel</button>
                <button type="submit" class="btn btn-md btn-danger" data-delete-account-confirm disabled>
                    Delete account
                </button>
            </div>
        </form>
    </div>
</div>

<script>
(() => {
    const modal = document.querySelector('[data-delete-account-modal]');
    if (!modal) return;
    const openBtn = document.querySelector('[data-delete-account-open]');
    const cancel  = modal.querySelector('[data-delete-account-cancel]');
    const input   = modal.querySelector('[data-delete-account-input]');
    const confirm = modal.querySelector('[data-delete-account-confirm]');
    const expected = input.getAttribute('data-expected') || '';

    const show = () => { modal.classList.remove('hidden'); modal.classList.add('flex'); input.value = ''; confirm.disabled = true; input.focus(); };
    const hide = () => { modal.classList.add('hidden'); modal.classList.remove('flex'); };

    openBtn?.addEventListener('click', show);
    cancel?.addEventListener('click', hide);
    modal.addEventListener('click', (e) => { if (e.target === modal) hide(); });
    // Enable the destructive button only on an exact username match. The
    // server re-checks this against the session user's own username too.
    input?.addEventListener('input', () => { confirm.disabled = (input.value !== expected); });
})();
</script>
{% endblock %}
