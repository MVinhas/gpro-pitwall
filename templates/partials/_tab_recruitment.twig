<div class="space-y-6">
    {# Notification Banner #}
    <div class="notice notice-info">
        <div class="flex">
            <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                </svg>
            </div>
            <div class="ml-3">
                <p class="font-bold">
                    Driver decisions happen on Mondays and Thursdays at 18:00 (Europe/Lisbon).
                </p>
                <p class="mt-1">
                    Offers rise incrementally starting on Mondays and Thursdays at 10:00 (Europe/Lisbon).
                </p>
            </div>
        </div>
    </div>

    <div class="bg-white shadow-lg rounded-xl overflow-hidden border border-slate-200">
        {# Header Section #}
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex flex-col sm:flex-row justify-between items-start sm:items-center">
            <div>
                <h2 class="t-heading">Recruitment Analyzer</h2>
                <p class="t-caption">Score the live GPRO driver market against your division's ideal pilot.</p>
            </div>
        </div>

        <div class="p-6">
            <form method="POST" action="/analyze_recruitment" class="space-y-6">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                <p class="t-caption">
                    The full GPRO driver market is pulled directly from
                    <code class="text-xs">GetMarketFile.asp</code> (refreshes hourly upstream;
                    cached locally for ~55 minutes).
                    {% if recruitment_updated_at %}
                        Last upstream update: <span class="font-semibold">{{ recruitment_updated_at }}</span>.
                    {% endif %}
                </p>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
                    {# Target Division #}
                    <div>
                        <label class="t-label block mb-1">Target Division</label>
                        <select name="target_division" class="form-select">
                            {% for div in divisions %}
                                <option value="{{ div }}" {{ div == active_division ? 'selected' : '' }}>{{ div }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {# Filters #}
                    <div class="pb-2">
                        <label class="inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="filter_offers" value="1" class="rounded border-slate-300 text-blue-600 shadow-sm focus:ring-blue-500 h-4 w-4">
                            <span class="ml-2 text-sm text-slate-700">Exclude drivers with offers</span>
                        </label>
                    </div>

                    {# Force a fresh market pull (bypasses cache). #}
                    <div class="pb-2">
                        <label class="inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="refresh_market" value="1" class="rounded border-slate-300 text-blue-600 shadow-sm focus:ring-blue-500 h-4 w-4">
                            <span class="ml-2 text-sm text-slate-700">Re-fetch market now</span>
                        </label>
                    </div>
                </div>

                <div class="flex justify-end border-t border-slate-100 pt-6">
                    {% if can_submit %}
                        <button type="submit" class="btn btn-md btn-primary">
                            Analyze Candidates
                        </button>
                    {% else %}
                        <div class="w-full md:w-1/2 p-4 bg-amber-50 border border-amber-200 rounded-md text-center">
                            <p class="text-sm font-medium text-amber-800 mb-2">Account Required</p>
                            <p class="text-xs text-amber-600 mb-3">
                                <a href="/login" class="underline hover:text-amber-800">Log in</a>
                                or
                                <a href="/register" class="underline hover:text-amber-800">register</a>
                                to analyze recruitment data.
                            </p>
                            <button type="button" disabled class="btn btn-md btn-disabled w-full">
                                Analyze Candidates (Locked)
                            </button>
                        </div>
                    {% endif %}
                </div>
            </form>

            {# Results Section #}
            {% if recruitment_error %}
                <div class="mt-6 notice notice-error">
                    <p class="font-bold">Analysis failed.</p>
                    <p class="mt-1">{{ recruitment_error }}</p>
                </div>
            {% elseif recruitment_results is defined %}
                <div class="mt-8">
                    <div class="flex justify-between items-end mb-4">
                        <h3 class="t-heading">
                            Candidates (Found: {{ pagination.total_items }})
                            {% if range_filters|length > 0 %}
                                <span class="t-caption font-medium">of {{ recruitment_unfiltered_total }}</span>
                            {% endif %}
                        </h3>
                        <span class="t-caption tabular-nums">
                            {% if pagination.total_pages > 0 %}
                                Page {{ pagination.current }} of {{ pagination.total_pages }}
                            {% else %}
                                No matching candidates
                            {% endif %}
                        </span>
                    </div>

                    {% set hasRangeFilters = range_filters|length > 0 %}
                    <details class="mb-4 rounded-lg border border-slate-200 bg-slate-50 group" {{ hasRangeFilters ? 'open' : '' }}>
                        <summary class="flex items-center justify-between px-4 py-3 cursor-pointer list-none">
                            <span class="inline-flex items-center gap-2">
                                <span class="text-slate-400 group-open:rotate-90 transition-transform">▸</span>
                                <span class="text-sm font-medium text-slate-700">Value range filters</span>
                            </span>
                            {% if hasRangeFilters %}
                                <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
                                    {{ range_filters|length }} active {{ range_filters|length == 1 ? 'range' : 'ranges' }}
                                </span>
                            {% endif %}
                        </summary>

                        <form method="GET" action="/" class="border-t border-slate-200 bg-white px-4 py-4">
                            <input type="hidden" name="main_tab" value="Recruitment Analyzer">
                            <input type="hidden" name="division_tab" value="{{ active_division }}">
                            <input type="hidden" name="sort" value="{{ sort.col }}">
                            <input type="hidden" name="order" value="{{ sort.order }}">

                            <p class="t-caption mb-3">
                                Leave either bound blank for a one-sided range. Minimum and maximum values are inclusive.
                            </p>

                            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
                                {% for field, label in range_filter_fields %}
                                    <div class="rounded-md border border-slate-200 p-3">
                                        <span class="t-label block mb-2">{{ label }}</span>
                                        <div class="grid grid-cols-2 gap-2">
                                            <div>
                                                <label for="min-{{ field }}" class="t-caption block mb-1">Minimum</label>
                                                <input type="number"
                                                       id="min-{{ field }}"
                                                       name="min_{{ field }}"
                                                       min="0"
                                                       step="1"
                                                       value="{{ range_filters[field].min is defined ? range_filters[field].min : '' }}"
                                                       placeholder="No min"
                                                       class="form-input">
                                            </div>
                                            <div>
                                                <label for="max-{{ field }}" class="t-caption block mb-1">Maximum</label>
                                                <input type="number"
                                                       id="max-{{ field }}"
                                                       name="max_{{ field }}"
                                                       min="0"
                                                       step="1"
                                                       value="{{ range_filters[field].max is defined ? range_filters[field].max : '' }}"
                                                       placeholder="No max"
                                                       class="form-input">
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>

                            <div class="flex justify-end gap-3 border-t border-slate-100 mt-4 pt-4">
                                {% set clearFilterHref = '?main_tab=Recruitment%20Analyzer&division_tab=' ~ (active_division|url_encode) ~ '&page=1&sort=' ~ (sort.col|url_encode) ~ '&order=' ~ (sort.order|url_encode) %}
                                <a href="{{ clearFilterHref }}" class="btn btn-md btn-secondary">Clear Filters</a>
                                <button type="submit" class="btn btn-md btn-primary">Apply Filters</button>
                            </div>
                        </form>
                    </details>

                    {% if favourite_tracks_available %}
                        <p class="t-caption mb-3">
                            <span class="font-semibold">Fav</span> = favourite tracks on the calendar.
                            <span class="font-semibold text-emerald-700">C·n</span> this season,
                            <span class="font-semibold text-emerald-700">N·n</span> next season. Hover for track names.
                        </p>
                    {% endif %}

                    {# Helper Macro for Headers #}
                    {% macro sortLink(label, col, currentSort, activeDivision, rangeFilterQuery) %}
                        {% set newOrder = (currentSort.col == col and currentSort.order == 'desc') ? 'asc' : 'desc' %}
                        {% set icon = '' %}
                        {% if currentSort.col == col %}
                            {% set icon = (currentSort.order == 'desc') ? ' ↓' : ' ↑' %}
                        {% endif %}
                        {% set href = '?main_tab=Recruitment%20Analyzer&division_tab=' ~ (activeDivision|url_encode) ~ '&page=1&sort=' ~ (col|url_encode) ~ '&order=' ~ (newOrder|url_encode) %}
                        {% if rangeFilterQuery %}
                            {% set href = href ~ '&' ~ rangeFilterQuery %}
                        {% endif %}
                        <a href="{{ href }}"
                           class="group inline-flex items-center hover:text-blue-600 transition-colors">
                             {{ label }}{{ icon }}
                        </a>
                    {% endmacro %}

                    <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-slate-300">
                                <thead class="bg-slate-50">
                                    <tr>
                                        <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-slate-900 sm:pl-6 cursor-pointer">
                                             {{ _self.sortLink('Rtg', 'rating', sort, active_division, range_filter_query) }}
                                        </th>
                                        <th scope="col" class="px-2 py-3.5 text-left text-sm font-semibold text-slate-900 cursor-pointer">
                                            {{ _self.sortLink('Name', 'NAME', sort, active_division, range_filter_query) }}
                                        </th>
                                        <th scope="col" class="px-2 py-3.5 text-center text-sm font-semibold text-slate-900 cursor-pointer">
                                            {{ _self.sortLink('OA', 'OA', sort, active_division, range_filter_query) }}
                                        </th>
                                        
                                        {# Stats #}
                                        {% set stats = ['CON', 'TAL', 'AGG', 'EXP', 'TEI', 'STA', 'CHA', 'MOT', 'WEI', 'AGE'] %}
                                        {% for stat in stats %}
                                            <th scope="col" class="px-1 py-3.5 text-center cursor-pointer">
                                                <span class="t-label">{{ _self.sortLink(stat|capitalize, stat, sort, active_division, range_filter_query) }}</span>
                                            </th>
                                        {% endfor %}
                                        
                                        {% if favourite_tracks_available %}
                                            <th scope="col" class="px-2 py-3.5 text-center text-sm font-semibold text-slate-900"
                                                title="Favourite tracks racing this season (C) and next season (N)">
                                                <span class="t-label">Fav</span>
                                            </th>
                                        {% endif %}

                                        <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-slate-900 cursor-pointer">
                                            {{ _self.sortLink('Salary', 'SAL', sort, active_division, range_filter_query) }}
                                        </th>
                                        <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-slate-900 cursor-pointer">
                                            {{ _self.sortLink('Fee', 'FEE', sort, active_division, range_filter_query) }}
                                        </th>
                                        <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-slate-900">Link</th>
                                    </tr>
                                </thead>
                                
                                <tbody class="divide-y divide-slate-200 bg-white">
                                    {% for d in recruitment_results %}
                                        {% set ratingColor = d.rating >= 90 ? 'text-emerald-600' : (d.rating >= 75 ? 'text-blue-600' : 'text-slate-600') %}
                                        <tr class="hover:bg-slate-50 transition-colors">
                                            <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-bold tabular-nums sm:pl-6 {{ ratingColor }}">
                                                {{ d.rating }}
                                            </td>
                                            <td class="whitespace-nowrap px-2 py-4 text-sm font-medium text-slate-900">
                                                {{ d.NAME }}
                                                {% if d.OFF > 0 %}
                                                    <span class="ml-2 inline-flex items-center rounded-full bg-red-50 px-1.5 py-0.5 text-[10px] font-medium text-red-700 ring-1 ring-inset ring-red-600/10">{{ d.OFF }} Off</span>
                                                {% endif %}
                                            </td>
                                            <td class="whitespace-nowrap px-2 py-4 text-center text-sm font-bold tabular-nums text-slate-700">{{ d.OA }}</td>

                                            <td class="whitespace-nowrap px-1 py-4 text-center text-sm tabular-nums text-slate-500">{{ d.CON }}</td>
                                            <td class="whitespace-nowrap px-1 py-4 text-center text-sm tabular-nums font-medium text-slate-700">{{ d.TAL }}</td>
                                            <td class="whitespace-nowrap px-1 py-4 text-center text-sm tabular-nums text-slate-500">{{ d.AGG }}</td>
                                            <td class="whitespace-nowrap px-1 py-4 text-center text-sm tabular-nums text-slate-500">{{ d.EXP }}</td>
                                            <td class="whitespace-nowrap px-1 py-4 text-center text-sm tabular-nums text-slate-500">{{ d.TEI }}</td>
                                            <td class="whitespace-nowrap px-1 py-4 text-center text-sm tabular-nums text-slate-500">{{ d.STA }}</td>
                                            <td class="whitespace-nowrap px-1 py-4 text-center text-sm tabular-nums text-slate-500">{{ d.CHA }}</td>
                                            <td class="whitespace-nowrap px-1 py-4 text-center text-sm tabular-nums text-slate-500">{{ d.MOT }}</td>
                                            <td class="whitespace-nowrap px-1 py-4 text-center text-sm tabular-nums text-slate-500">{{ d.WEI }}</td>
                                            <td class="whitespace-nowrap px-1 py-4 text-center text-sm tabular-nums font-bold text-slate-500">{{ d.AGE }}</td>

                                            {% if favourite_tracks_available %}
                                                <td class="whitespace-nowrap px-2 py-4 text-center text-sm">
                                                    <div class="inline-flex items-center gap-1">
                                                        {% set curOn = d.FAV_current > 0 %}
                                                        {% set nxtOn = d.FAV_next > 0 %}
                                                        <span class="inline-flex items-center rounded px-1.5 py-0.5 text-[11px] font-semibold tabular-nums ring-1 ring-inset {{ curOn ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20' : 'bg-slate-50 text-slate-400 ring-slate-200' }}"
                                                              title="{{ curOn ? 'This season: ' ~ d.FAV_current_names|join(', ') : 'No favourite tracks this season' }}">C·{{ d.FAV_current }}</span>
                                                        <span class="inline-flex items-center rounded px-1.5 py-0.5 text-[11px] font-semibold tabular-nums ring-1 ring-inset {{ nxtOn ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20' : 'bg-slate-50 text-slate-400 ring-slate-200' }}"
                                                              title="{{ nxtOn ? 'Next season: ' ~ d.FAV_next_names|join(', ') : 'No favourite tracks next season' }}">N·{{ d.FAV_next }}</span>
                                                    </div>
                                                </td>
                                            {% endif %}

                                            <td class="whitespace-nowrap px-3 py-4 text-right text-sm tabular-nums text-slate-600">${{ d.SAL|number_format }}</td>
                                            <td class="whitespace-nowrap px-3 py-4 text-right text-sm tabular-nums text-slate-600">${{ d.FEE|number_format }}</td>
                                            
                                            <td class="whitespace-nowrap px-3 py-4 text-center text-sm">
                                                {% if d.ID > 0 %}
                                                    <a href="https://gpro.net/gb/DriverProfile.asp?ID={{ d.ID }}" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 transition-colors text-lg" title="Open GPRO Profile">🔗</a>
                                                {% else %}
                                                    <span class="text-slate-300">-</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="{{ favourite_tracks_available ? 17 : 16 }}" class="px-6 py-10 text-center text-sm text-slate-500 bg-slate-50">
                                                No candidates found.
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        
                        {# Pagination Controls #}
                        {% if pagination.total_pages > 1 %}
                            <div class="bg-white px-4 py-3 flex items-center justify-between border-t border-slate-200 sm:px-6">
                                {% set navigationParams = 'main_tab=Recruitment%20Analyzer&division_tab=' ~ (active_division|url_encode) ~ '&sort=' ~ (sort.col|url_encode) ~ '&order=' ~ (sort.order|url_encode) %}
                                {% if range_filter_query %}
                                    {% set navigationParams = navigationParams ~ '&' ~ range_filter_query %}
                                {% endif %}
                                
                                {# Mobile: prev/next only. #}
                                <div class="flex flex-1 items-center justify-between sm:hidden">
                                    {% if pagination.current > 1 %}
                                        <a href="?{{ navigationParams }}&page={{ pagination.current - 1 }}" class="btn btn-md btn-secondary">Previous</a>
                                    {% else %}
                                        <span></span>
                                    {% endif %}
                                    <span class="text-sm text-slate-700 tabular-nums">Page {{ pagination.current }} / {{ pagination.total_pages }}</span>
                                    {% if pagination.current < pagination.total_pages %}
                                        <a href="?{{ navigationParams }}&page={{ pagination.current + 1 }}" class="btn btn-md btn-secondary">Next</a>
                                    {% else %}
                                        <span></span>
                                    {% endif %}
                                </div>

                                <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                                    <div>
                                        <p class="text-sm text-slate-700 tabular-nums">
                                            Showing <span class="font-medium">{{ (pagination.current - 1) * pagination.per_page + 1 }}</span> to <span class="font-medium">{{ min(pagination.current * pagination.per_page, pagination.total_items) }}</span> of <span class="font-medium">{{ pagination.total_items }}</span> results
                                        </p>
                                    </div>
                                    <div>
                                        <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                                            {% if pagination.current > 1 %}
                                                <a href="?{{ navigationParams }}&page={{ pagination.current - 1 }}" aria-label="Previous page" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-slate-300 bg-white text-sm font-medium text-slate-500 hover:bg-slate-50">
                                                     «
                                                </a>
                                            {% endif %}

                                            {# Windowed page list: 1 … current±2 … last. Keeps the bar
                                               usable when the market yields hundreds of pages. #}
                                            {% set window = 2 %}
                                            {% set win_start = max(2, pagination.current - window) %}
                                            {% set win_end = min(pagination.total_pages - 1, pagination.current + window) %}
                                            {% set pages = [1] %}
                                            {% if win_start <= win_end %}
                                                {% set pages = pages|merge(win_start..win_end) %}
                                            {% endif %}
                                            {% if pagination.total_pages > 1 %}
                                                {% set pages = pages|merge([pagination.total_pages]) %}
                                            {% endif %}
                                            {% for i in pages %}
                                                {% if not loop.first and i > pages[loop.index0 - 1] + 1 %}
                                                    <span class="relative inline-flex items-center px-3 py-2 border border-slate-300 bg-white text-sm text-slate-400 select-none">…</span>
                                                {% endif %}
                                                <a href="?{{ navigationParams }}&page={{ i }}"
                                                    {% if i == pagination.current %}aria-current="page"{% endif %}
                                                    class="relative inline-flex items-center px-4 py-2 border text-sm font-medium {{ i == pagination.current ? 'z-10 bg-blue-50 border-blue-500 text-blue-600' : 'bg-white border-slate-300 text-slate-500 hover:bg-slate-50' }}">
                                                    {{ i }}
                                                </a>
                                            {% endfor %}

                                            {% if pagination.current < pagination.total_pages %}
                                                <a href="?{{ navigationParams }}&page={{ pagination.current + 1 }}" aria-label="Next page" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-slate-300 bg-white text-sm font-medium text-slate-500 hover:bg-slate-50">
                                                    »
                                                </a>
                                            {% endif %}
                                        </nav>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
