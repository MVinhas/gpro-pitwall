{% import "partials/_localtime.twig" as t %}
<div class="mb-4 rounded-md bg-amber-50 border-l-4 border-amber-400 p-4 shadow-sm">
    <p class="text-sm text-amber-800">
        <span class="font-bold">Changed the car?</span>
        Re-sync first — the strategy below uses your last-synced car data{% if user.last_synced_at %} (last sync: {{ t.localtime(user.last_synced_at, 'datetime') }}){% endif %}.
    </p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

    {# LEFT: Configuration Panel #}
    <div class="lg:col-span-3">
        <form method="POST" action="/calculate_strategy" id="stratForm">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            {# CARD 1: DRIVER — informative, from the last sync #}
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-4">
                <div class="px-4 py-2 border-b border-slate-200 bg-slate-50 flex items-baseline justify-between">
                    <h3 class="t-section">Driver</h3>
                    <span class="text-[10px] text-slate-400">from last sync</span>
                </div>
                {% set d = strategy_results.stats.driver %}
                <div class="px-4 py-3 grid grid-cols-2 gap-x-8 gap-y-1 text-xs">
                    {% for key, label in {
                        'concentration':     'Concentration',
                        'talent':            'Talent',
                        'aggressiveness':    'Aggressiveness',
                        'experience':        'Experience',
                        'technical_insight': 'Tech Insight',
                        'weight':            'Weight'
                    } %}
                        <span class="flex justify-between gap-2">
                            <span class="text-slate-400">{{ label }}</span>
                            <span class="font-semibold text-slate-700 tabular-nums">{{ d[key] }}</span>
                        </span>
                    {% endfor %}
                </div>
            </div>

            {# CARD 2: TEAM — informative, from the last sync #}
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-4">
                <div class="px-4 py-2 border-b border-slate-200 bg-slate-50 flex items-baseline justify-between">
                    <h3 class="t-section">Team</h3>
                    <span class="text-[10px] text-slate-400">from last sync</span>
                </div>
                <div class="px-4 py-3 space-y-1 text-xs">
                    <p class="t-label">Car Levels</p>
                    <div class="grid grid-cols-2 gap-x-8 gap-y-1">
                        {% for key, label in { 'lvlEngine': 'Engine', 'lvlSusp': 'Suspension', 'lvlElectronics': 'Electronics' } %}
                            <span class="flex justify-between gap-2">
                                <span class="text-slate-400">{{ label }}</span>
                                <span class="font-semibold text-slate-700 tabular-nums">{{ strategy_results.stats.car[key] }}</span>
                            </span>
                        {% endfor %}
                    </div>
                    <p class="t-label pt-2">Staff</p>
                    <div class="grid grid-cols-2 gap-x-8 gap-y-1">
                        <span class="flex justify-between gap-2">
                            <span class="text-slate-400">Concentration</span>
                            <span class="font-semibold text-slate-700 tabular-nums">{{ strategy_results.stats.staff.concentration }}</span>
                        </span>
                        <span class="flex justify-between gap-2">
                            <span class="text-slate-400">Stress Handling</span>
                            <span class="font-semibold text-slate-700 tabular-nums">{{ strategy_results.stats.staff.stressHandling }}</span>
                        </span>
                    </div>
                    <p class="t-label pt-2">Tech Director</p>
                    <div class="grid grid-cols-2 gap-x-8 gap-y-1">
                        <span class="flex justify-between gap-2">
                            <span class="text-slate-400">Experience</span>
                            <span class="font-semibold text-slate-700 tabular-nums">{{ strategy_results.stats.td.experience }}</span>
                        </span>
                        <span class="flex justify-between gap-2">
                            <span class="text-slate-400">Pit Coordination</span>
                            <span class="font-semibold text-slate-700 tabular-nums">{{ strategy_results.stats.td.pitCoordination }}</span>
                        </span>
                    </div>
                </div>
            </div>

            {# CARD 3: RACE SETTINGS #}
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-4">
                <div class="px-4 py-3 border-b border-slate-200 bg-slate-50">
                    <h3 class="t-section">Race Settings</h3>
                </div>
                <div class="p-4 space-y-3">
                    <div class="flex items-center justify-between gap-3">
                        <label class="t-label">Track Temp</label>
                        <div class="form-input-group w-24">
                            <input type="number" name="temp" value="{{ strategy_results.inputs.temp ?? '' }}" placeholder="Auto" step="0.1" class="form-input-compact">
                            <span class="form-input-addon">°C</span>
                        </div>
                    </div>
                    <div class="flex items-center justify-between gap-3">
                        <label class="t-label">Humidity</label>
                        <div class="form-input-group w-24">
                            <input type="number" name="humidity" value="{{ strategy_results.inputs.hum ?? '' }}" placeholder="Auto" class="form-input-compact">
                            <span class="form-input-addon">%</span>
                        </div>
                    </div>
                    <div>
                        <label class="t-label block mb-1">Clear Track Risk</label>
                        <div class="flex items-center gap-3">
                            <input type="range" name="risk" min="0" max="100"
                                   value="{{ strategy_results.inputs.risk ?? 0 }}"
                                   data-strategy-fragment-trigger data-slider-live
                                   class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer">
                            <span data-slider-value
                                  class="text-sm font-bold text-blue-600 w-10 text-right">{{ strategy_results.inputs.risk ?? 0 }}</span>
                        </div>
                    </div>
                    <div>
                        <label class="t-label block mb-1">Target Wear Limit (%)</label>
                        <div class="flex items-center gap-3">
                            <input type="range" name="target_wear" min="0" max="100"
                                   value="{{ strategy_results.inputs.target_wear ?? 15 }}"
                                   data-strategy-fragment-trigger data-slider-live
                                   class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer">
                            <span data-slider-value
                                  class="text-sm font-bold text-blue-600 w-10 text-right">{{ strategy_results.inputs.target_wear ?? 15 }}</span>
                        </div>
                    </div>
                    <div>
                        {% set bs = strategy_results.inputs.boost_stints ?? 0 %}
                        <label class="t-label block mb-1" title="Each stint runs 3 boost laps. Extra fuel is spread across race stints.">Boost Lap Stints</label>
                        <select name="boost_stints" data-strategy-fragment-trigger class="form-select">
                            <option value="0" {{ bs == 0 ? 'selected' }}>0 — no boost (0 laps)</option>
                            <option value="1" {{ bs == 1 ? 'selected' }}>1 stint (3 boost laps)</option>
                            <option value="2" {{ bs == 2 ? 'selected' }}>2 stints (6 boost laps)</option>
                            <option value="3" {{ bs == 3 ? 'selected' }}>3 stints (9 boost laps)</option>
                        </select>
                    </div>
                </div>
            </div>

            {# Hidden Setup Inputs #}
            <div class="hidden">
               <input type="hidden" name="q1_temp" value="{{ strategy_results.weather_inputs.Q1.temp }}">
               <input type="hidden" name="q1_weather" value="{{ strategy_results.weather_inputs.Q1.weather }}">
               <input type="hidden" name="q2_temp" value="{{ strategy_results.weather_inputs.Q2.temp }}">
               <input type="hidden" name="q2_weather" value="{{ strategy_results.weather_inputs.Q2.weather }}">
               <input type="hidden" name="race_weather" value="{{ strategy_results.weather_inputs.Race.weather }}">
            </div>

            <button type="submit" id="stratBtn"
                class="btn btn-lg btn-primary w-full">
                Calculate Strategy
            </button>
        </form>
    </div>

    {# RIGHT: Results Display #}
    <div class="lg:col-span-9" id="strategy-results-card">
        {% include 'partials/_strategy_results.twig' %}
    </div>
</div>

{# Loading + risk-slider fragment refresh #}
<script>
(() => {
    const form = document.getElementById('stratForm');
    const card = document.getElementById('strategy-results-card');
    if (!form || !card) return;

    form.addEventListener('submit', () => {
        const btn = document.getElementById('stratBtn');
        if (btn) {
            btn.disabled = true;
            btn.classList.add('opacity-75', 'cursor-not-allowed');
            btn.innerHTML = 'Processing...';
        }
    });

    let pending = null;

    // The fragment swap re-renders the Race Engineer accordion with its
    // server-side default (open), so a collapsed state would be lost on
    // every slider change. Remember the user's choice for the session.
    const RE_KEY = 'raceEngineerOpen';
    const applyAccordionState = () => {
        const d = card.querySelector('#race-engineer');
        const saved = sessionStorage.getItem(RE_KEY);
        if (d && saved !== null) d.open = saved === '1';
    };
    // <details> toggle events don't bubble — listen in the capture phase.
    document.addEventListener('toggle', (e) => {
        if (e.target.id === 'race-engineer') {
            sessionStorage.setItem(RE_KEY, e.target.open ? '1' : '0');
        }
    }, true);
    applyAccordionState();

    // Live slider value labels (dragging updates the number without server roundtrip).
    document.addEventListener('input', (e) => {
        if (!e.target.matches('[data-slider-live]')) return;
        const label = e.target.parentElement.querySelector('[data-slider-value]');
        if (label) label.textContent = e.target.value;
    });

    // Sliders + selects flagged as fragment triggers re-run the calc and swap the panel.
    document.addEventListener('change', async (e) => {
        if (!e.target.matches('[data-strategy-fragment-trigger]')) return;
        if (pending) pending.abort();
        pending = new AbortController();
        const data = new FormData(form);
        try {
            const res = await fetch('/strategy_fragment', {
                method: 'POST',
                body: data,
                signal: pending.signal,
                headers: { 'X-Requested-With': 'fetch' },
            });
            if (!res.ok) return;
            card.innerHTML = await res.text();
            applyAccordionState();
        } catch (err) {
            if (err.name !== 'AbortError') console.error(err);
        }
    });
})();
</script>
