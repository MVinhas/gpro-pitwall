{# division_tab is only meaningful on the two division screens. Carrying it
   in every URL pollutes the bar and confuses users on the Car Wear /
   Strategy / Recruitment tabs. Compute per-link. #}
{% set division_tabs = ['Division Baseline', 'Division Differences'] %}
{% macro tab_href(section, active_division, active_track, division_tabs) %}
    {%- set href = '?main_tab=' ~ section|url_encode -%}
    {%- if section in division_tabs -%}
        {%- set href = href ~ '&division_tab=' ~ active_division|url_encode -%}
    {%- endif -%}
    {%- if active_track -%}
        {%- set href = href ~ '&track=' ~ active_track|url_encode -%}
    {%- endif -%}
    {{- href -}}
{% endmacro %}

<nav class="mb-8">
    <div class="md:hidden">
        {# Mobile Dropdown fallback #}
        <label for="tabs" class="sr-only">Select a tab</label>
        <select id="tabs" name="tabs" class="block w-full rounded-md border-gray-300 focus:border-blue-500 focus:ring-blue-500" onchange="window.location.href=this.value">
            {% for section in main_sections %}
                <option value="{{ _self.tab_href(section, active_division, active_track, division_tabs) }}" {{ section == active_main_tab ? 'selected' : '' }}>
                    {{ section }}
                </option>
            {% endfor %}
        </select>
    </div>

    <div class="hidden md:block">
        <div class="border-b border-slate-200">
            <nav class="-mb-px flex space-x-8" aria-label="Tabs">
                {% for section in main_sections %}
                    {% set is_active = (section == active_main_tab) %}
                    <a href="{{ _self.tab_href(section, active_division, active_track, division_tabs) }}"
                       class="whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium transition-colors duration-200
                              {{ is_active
                                 ? 'border-blue-600 text-blue-600'
                                 : 'border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700'
                              }}">
                        {{ section }}
                    </a>
                {% endfor %}
            </nav>
        </div>
    </div>
</nav>