<div class="max-w-3xl mx-auto space-y-6">

    <div>
        <h2 class="t-display">Race Weekend Cockpit</h2>
        <p class="t-caption">Your pre-qualifying decision board.</p>
    </div>

    {% if cockpit_error %}
        <div class="rounded-md bg-red-50 border-l-4 border-red-400 p-4">
            <p class="text-sm font-bold text-red-800">Couldn't load cockpit data</p>
            <p class="text-sm text-red-700 mt-1">{{ cockpit_error }}</p>
        </div>
    {% elseif pha is not defined %}
        <div class="rounded-md bg-slate-50 border border-dashed border-slate-200 p-8 text-center">
            <p class="t-heading text-slate-500">No synced data yet</p>
            <p class="t-caption mt-1">Add your API token and sync to see your push recommendation.</p>
        </div>
    {% else %}

        {# PHA MATCH CARD #}
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
                <div>
                    <h3 class="t-section">Power / Handling / Acceleration match</h3>
                    <p class="t-heading mt-0.5">{{ pha_track_name }}</p>
                </div>
                {% if pha.favourite %}
                    <span class="inline-flex items-center rounded-md bg-amber-50 px-2 py-1 text-xs font-semibold text-amber-700 ring-1 ring-inset ring-amber-600/20">
                        ★ Favourite track
                    </span>
                {% endif %}
            </div>

            <div class="p-6 space-y-6">

                {# VERDICT BANNER — shown only for push / all_in #}
                {% if pha.verdict == 'all_in' %}
                    <div class="rounded-lg bg-emerald-600 px-5 py-4 text-white shadow-sm">
                        <p class="text-lg font-extrabold tracking-wide">ALL IN</p>
                        <p class="text-sm text-emerald-50 mt-0.5">
                            Your car's strength matches this track's demand <em>and</em> it's your driver's favourite. Push hard and spend your boost laps.
                        </p>
                    </div>
                {% elseif pha.verdict == 'push' %}
                    <div class="rounded-lg bg-blue-600 px-5 py-4 text-white shadow-sm">
                        <p class="text-lg font-extrabold tracking-wide">PUSH</p>
                        <p class="text-sm text-blue-50 mt-0.5">
                            {% if pha.pha_similar %}
                                Your car's P/H/A profile matches this track's demand — a good weekend to push.
                            {% else %}
                                This is your driver's favourite track — worth pushing.
                            {% endif %}
                        </p>
                    </div>
                {% endif %}

                {# ATTRIBUTE COMPARISON #}
                <div>
                    <div class="grid grid-cols-12 gap-2 pb-2 mb-1 border-b border-slate-100">
                        <span class="col-span-4 t-label">Attribute</span>
                        <span class="col-span-3 t-label text-center">Track</span>
                        <span class="col-span-3 t-label text-center">Car</span>
                        <span class="col-span-2 t-label text-center">Match</span>
                    </div>
                    {% for attr, d in pha.attributes %}
                        <div class="grid grid-cols-12 gap-2 py-2 items-center {{ d.aligned ? 'bg-emerald-50/60 rounded-md' : '' }}">
                            <span class="col-span-4 text-sm font-medium text-slate-800 capitalize pl-1">{{ attr }}</span>
                            <span class="col-span-3 text-center">
                                <span class="t-value">{{ d.track }}</span>
                                <span class="t-caption">#{{ d.track_rank }}</span>
                            </span>
                            <span class="col-span-3 text-center">
                                <span class="t-value">{{ d.car }}</span>
                                <span class="t-caption">#{{ d.car_rank }}</span>
                            </span>
                            <span class="col-span-2 text-center">
                                {% if d.aligned %}
                                    <span class="text-emerald-600 font-bold">✓</span>
                                {% else %}
                                    <span class="text-slate-300">—</span>
                                {% endif %}
                            </span>
                        </div>
                    {% endfor %}
                </div>

                <p class="t-caption">
                    Rank #1 = the most-demanded (track) or strongest (car) attribute. A match across the top
                    two means your car is built for what this track rewards.
                </p>
            </div>
        </div>

        {# BOOST LAPS #}
        {% if boost_costs is defined %}
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
                    <h3 class="t-section">Boost laps</h3>
                </div>
                <div class="p-6 space-y-4">
                    {% if pha.verdict == 'all_in' %}
                        <p class="text-sm text-emerald-700 font-medium">
                            Verdict is ALL IN — spend your boost laps. Extra fuel to budget:
                        </p>
                    {% elseif pha.verdict == 'push' %}
                        <p class="text-sm text-blue-700 font-medium">
                            Pushing this weekend — consider boost laps. Extra fuel to budget:
                        </p>
                    {% else %}
                        <p class="t-caption">
                            No strong push signal — boost laps are optional. Extra fuel if you use them:
                        </p>
                    {% endif %}

                    <div class="grid grid-cols-3 gap-3">
                        {% for laps, fuel in boost_costs %}
                            <div class="rounded-lg border border-slate-200 p-3 text-center">
                                <p class="t-label">{{ laps }} boost lap{{ laps > 1 ? 's' : '' }}</p>
                                <p class="t-value mt-1">+{{ fuel }} L</p>
                            </div>
                        {% endfor %}
                    </div>

                    <p class="t-caption">
                        Up to 3 sets per race. Fuel shown is the extra load on top of your normal
                        race fuel; add it when setting your strategy.
                    </p>
                </div>
            </div>
        {% endif %}

        {# Remaining cockpit steps to wire next. #}
        <p class="t-caption text-center">Next: weather call, and a jump to your race strategy.</p>

    {% endif %}
</div>
