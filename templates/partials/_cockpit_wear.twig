<div class="px-6 py-4 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
    <h3 class="t-section">Car wear</h3>
    <span class="t-caption">Risk: <span class="font-semibold text-slate-700">{{ cockpit_risk }}</span></span>
</div>
<div class="p-6 space-y-4">
    <form method="GET" action="" class="space-y-2" data-cockpit-wear-form>
        <input type="hidden" name="main_tab" value="Cockpit">
        {% if active_track %}<input type="hidden" name="track" value="{{ active_track }}">{% endif %}
        <label class="t-label block">Clear Track Risk</label>
        <div class="flex items-center gap-3">
            <input type="range" name="cockpit_risk" min="0" max="100" value="{{ cockpit_risk }}"
                   data-cockpit-risk-slider
                   class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer">
            <span data-cockpit-risk-value class="text-sm font-bold text-blue-600 w-10 text-right">{{ cockpit_risk }}</span>
        </div>
    </form>

    <p class="text-sm font-medium {{ wear_advice.swap is not empty ? 'text-red-700' : (wear_advice.risky is not empty ? 'text-amber-700' : (wear_advice.watch is not empty ? 'text-slate-700' : 'text-emerald-700')) }}">
        {{ wear_advice.headline }}
    </p>

    {% if wear_advice.swap is not empty %}
        <div>
            <p class="t-label mb-2 text-red-700">Will not finish the race — replace it</p>
            <ul class="space-y-1">
                {% for p in wear_advice.swap %}
                    <li class="rounded-md bg-red-50 px-3 py-2 ring-1 ring-inset ring-red-600/10">
                        <div class="flex justify-between items-baseline">
                            <span class="text-sm font-semibold text-slate-900">{{ p.part }}</span>
                            <span class="t-caption">Lvl {{ p.level }} · now at {{ p.start }}%</span>
                        </div>
                        <p class="t-caption text-red-700 mt-0.5">
                            If untouched, ends the race at <span class="font-semibold">{{ p.end }}%</span>.
                        </p>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if wear_advice.risky is not empty %}
        <div>
            <p class="t-label mb-2 text-amber-700">Will finish in the red</p>
            <ul class="space-y-1">
                {% for p in wear_advice.risky %}
                    <li class="rounded-md bg-amber-50 px-3 py-2 ring-1 ring-inset ring-amber-600/10">
                        <div class="flex justify-between items-baseline">
                            <span class="text-sm font-semibold text-slate-900">{{ p.part }}</span>
                            <span class="t-caption">Lvl {{ p.level }} · now at {{ p.start }}%</span>
                        </div>
                        <p class="t-caption text-amber-800 mt-0.5">
                            If untouched, ends the race at <span class="font-semibold">{{ p.end }}%</span>.
                        </p>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if wear_advice.watch is not empty %}
        <div>
            <p class="t-label mb-2">Watch</p>
            <ul class="space-y-1">
                {% for p in wear_advice.watch %}
                    <li class="rounded-md bg-slate-50 px-3 py-2 ring-1 ring-inset ring-slate-200">
                        <div class="flex justify-between items-baseline">
                            <span class="text-sm font-semibold text-slate-900">{{ p.part }}</span>
                            <span class="t-caption">Lvl {{ p.level }} · now at {{ p.start }}%</span>
                        </div>
                        <p class="t-caption mt-0.5">
                            If untouched, ends the race at <span class="font-semibold">{{ p.end }}%</span>.
                        </p>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if swap_advice is defined and swap_advice is not empty %}
        <div class="rounded-lg border border-slate-200 bg-white p-4 space-y-4">
            <p class="t-label text-slate-700">Swap options</p>
            {% for part, opts in swap_advice %}
                {% set cur = opts.current %}
                <div class="rounded-md border border-slate-200 p-3">
                    <div class="flex items-baseline justify-between mb-3">
                        <span class="text-sm font-semibold text-slate-900">{{ part }}</span>
                        <span class="t-caption">currently Lvl {{ cur.level }} · {{ cur.start }}% → {{ cur.end }}% if untouched</span>
                    </div>

                    {% if opts.picks is empty %}
                        <p class="t-caption">No affordable, survivable option within your group's range.</p>
                    {% else %}
                        {# Picks are pre-sorted tier ASC then cost ASC, so the
                           best pick is always the first row. Highlight it only
                           if that best tier is Perfect (0) or Top match (1). #}
                        {% set top_pick_qualifies = opts.picks[0].pha_tier in [0, 1] %}
                        <ul class="space-y-2">
                            {% for r in opts.picks %}
                                {% set slot_label = {
                                    'free_downgrade': 'Free downgrade',
                                    'downgrade':      'Downgrade',
                                    'sidegrade':      'Sidegrade',
                                    'upgrade':        'Upgrade',
                                }[r.slot] %}
                                {% set tier_label = {0: 'Perfect', 1: 'Top match'}[r.pha_tier] ?? null %}
                                {% set tier_bg = {
                                    0: 'bg-emerald-100 text-emerald-800',
                                    1: 'bg-lime-100 text-lime-800',
                                }[r.pha_tier] ?? '' %}
                                {% set tier_help = {
                                    0: 'Your car PHA ranking exactly mirrors the track demand — strongest matches most-demanded, all the way down.',
                                    1: 'Your car top attribute matches what the track demands most; the lower two may differ.',
                                }[r.pha_tier] ?? '' %}
                                {% set row_bg = loop.first and top_pick_qualifies
                                    ? 'bg-emerald-50 border-emerald-200'
                                    : 'bg-white border-slate-200' %}
                                <li class="rounded-md border {{ row_bg }} px-3 py-2">
                                    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                                        <span class="text-xs font-semibold uppercase tracking-wide text-slate-500">{{ slot_label }}</span>
                                        <span class="text-sm font-semibold text-slate-900">Lvl {{ r.level }}</span>
                                        <span class="t-caption">{{ r.cost > 0 ? '$' ~ r.cost|number_format : 'free' }}</span>
                                        <span class="t-caption">ends at {{ r.end }}%</span>
                                        {% if tier_label %}
                                            <span class="ml-auto inline-flex items-center rounded-md px-2 py-0.5 text-xs font-semibold cursor-help {{ tier_bg }}"
                                                  title="{{ tier_help }}">
                                                {{ tier_label }}
                                            </span>
                                        {% endif %}
                                    </div>
                                    <p class="t-caption mt-1">{{ r.rationale }}</p>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <p class="t-caption">
        Move the slider to model different driver-risk levels. The Car Wear tab
        gives the full breakdown.
    </p>

    <details class="group rounded-lg border border-slate-200">
        <summary class="flex cursor-pointer select-none list-none items-center justify-between px-4 py-3 text-xs font-semibold uppercase tracking-wide text-slate-500 hover:bg-slate-50">
            PHA contribution per part
            <svg class="h-4 w-4 shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
        </summary>
        <div class="border-t border-slate-200 px-4 pb-4 pt-3 space-y-3">
            <p class="t-caption pt-1">Use this to manually calculate PHA shifts when swapping parts. Each number is the contribution per level — multiply by the level change to get the delta.</p>
            <table class="w-full text-xs">
                <thead>
                    <tr class="border-b border-slate-200">
                        <th class="pb-1.5 text-left font-semibold text-slate-600">Part</th>
                        <th class="pb-1.5 text-center font-semibold text-blue-600">P</th>
                        <th class="pb-1.5 text-center font-semibold text-amber-600">H</th>
                        <th class="pb-1.5 text-center font-semibold text-emerald-600">A</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% set pha_table = [
                        { part: 'Engine',     p: 6, h: 0, a: 2 },
                        { part: 'Gearbox',    p: 3, h: 1, a: 5 },
                        { part: 'Front Wing', p: 1, h: 3, a: 0 },
                        { part: 'Rear Wing',  p: 0, h: 2, a: 3 },
                        { part: 'Electronics',p: 2, h: 0, a: 2 },
                        { part: 'Chassis',    p: 1, h: 2, a: 2 },
                        { part: 'Suspension', p: 0, h: 2, a: 2 },
                        { part: 'Brakes',     p: 0, h: 2, a: 0 },
                        { part: 'Cooling',    p: 2, h: 0, a: 0 },
                        { part: 'Sidepods',   p: 1, h: 1, a: 0 },
                        { part: 'Underbody',  p: 0, h: 1, a: 1 },
                    ] %}
                    {% for row in pha_table %}
                        <tr>
                            <td class="py-1.5 text-slate-700">{{ row.part }}</td>
                            <td class="py-1.5 text-center {{ row.p > 0 ? 'font-semibold text-blue-600' : 'text-slate-300' }}">{{ row.p > 0 ? row.p : '—' }}</td>
                            <td class="py-1.5 text-center {{ row.h > 0 ? 'font-semibold text-amber-600' : 'text-slate-300' }}">{{ row.h > 0 ? row.h : '—' }}</td>
                            <td class="py-1.5 text-center {{ row.a > 0 ? 'font-semibold text-emerald-600' : 'text-slate-300' }}">{{ row.a > 0 ? row.a : '—' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </details>
</div>
