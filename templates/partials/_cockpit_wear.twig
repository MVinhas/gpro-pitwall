{# Rendered standalone by the fragment endpoint (fragment=cockpit_wear) and
   swapped into the #wear <details> innerHTML — so this file is summary + body
   only, never its own <details>. The verdict chip comes from the shared
   _wear_verdict.twig partial (same source as the board tile). #}
<summary class="cursor-pointer list-none p-4 sm:p-6 flex flex-wrap items-center justify-between gap-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600">
    <span class="flex items-center gap-3">
        <span>
            <h4 class="t-section">Car wear</h4>
        </span>
    </span>
    <span class="flex items-center gap-6 text-right">
        {% include 'partials/_wear_verdict.twig' with { wear_advice: wear_advice, site: 'summary' } only %}
        <span class="text-slate-400 group-open/wear:rotate-90 transition-transform" aria-hidden="true">▸</span>
    </span>
</summary>
<div class="px-4 pb-4 sm:px-6 sm:pb-6 space-y-4">
    <form method="GET" action="" class="space-y-2" data-cockpit-wear-form>
        <input type="hidden" name="main_tab" value="Cockpit">
        {% if active_track %}<input type="hidden" name="track" value="{{ active_track }}">{% endif %}
        <label class="t-label block">Clear Track Risk</label>
        <div class="flex items-center gap-3">
            <input type="range" name="cockpit_risk" min="0" max="100" value="{{ cockpit_risk }}"
                   data-cockpit-risk-slider
                   class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer">
            <span data-cockpit-risk-value class="text-sm font-bold text-blue-600 w-10 text-right">{{ cockpit_risk }}</span>
        </div>
        <noscript><button type="submit" class="btn btn-sm btn-secondary w-full">Update</button></noscript>
    </form>

    {% if wear_advice.swap is empty and wear_advice.risky is empty and wear_advice.watch is empty %}
        <p class="text-sm font-medium text-emerald-700">{{ wear_advice.headline }}</p>
    {% else %}
        <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
                <thead>
                    <tr class="text-left text-slate-500">
                        <th class="py-1.5 pr-3 font-medium">Part</th>
                        <th class="py-1.5 px-2 font-medium text-right">Lvl</th>
                        <th class="py-1.5 px-2 font-medium text-right">Wear</th>
                        <th class="py-1.5 pl-2 font-medium text-right">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% for p in wear_advice.swap %}
                        <tr class="bg-red-50">
                            <td class="py-1.5 pr-3 font-medium text-slate-900">{{ p.part }}</td>
                            <td class="py-1.5 px-2 text-right tabular-nums text-slate-600">{{ p.level }}</td>
                            <td class="py-1.5 px-2 text-right tabular-nums text-slate-700">{{ p.start }}% → {{ p.end }}%</td>
                            <td class="py-1.5 pl-2 text-right"><span class="inline-flex items-center rounded px-1.5 py-0.5 text-xs font-semibold bg-red-100 text-red-800">Replace</span></td>
                        </tr>
                    {% endfor %}
                    {% for p in wear_advice.risky %}
                        <tr class="bg-amber-50">
                            <td class="py-1.5 pr-3 font-medium text-slate-900">{{ p.part }}</td>
                            <td class="py-1.5 px-2 text-right tabular-nums text-slate-600">{{ p.level }}</td>
                            <td class="py-1.5 px-2 text-right tabular-nums text-slate-700">{{ p.start }}% → {{ p.end }}%</td>
                            <td class="py-1.5 pl-2 text-right"><span class="inline-flex items-center rounded px-1.5 py-0.5 text-xs font-semibold bg-amber-100 text-amber-800">Red</span></td>
                        </tr>
                    {% endfor %}
                    {% for p in wear_advice.watch %}
                        <tr>
                            <td class="py-1.5 pr-3 font-medium text-slate-900">{{ p.part }}</td>
                            <td class="py-1.5 px-2 text-right tabular-nums text-slate-600">{{ p.level }}</td>
                            <td class="py-1.5 px-2 text-right tabular-nums text-slate-700">{{ p.start }}% → {{ p.end }}%</td>
                            <td class="py-1.5 pl-2 text-right"><span class="inline-flex items-center rounded px-1.5 py-0.5 text-xs font-semibold bg-slate-100 text-slate-700">Watch</span></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if swap_advice is defined and swap_advice is not empty %}
        <div class="rounded-lg border border-slate-200 bg-surface p-4 space-y-4">
            <p class="t-label text-slate-700">Swap options</p>
            {% for part, opts in swap_advice %}
                {% set cur = opts.current %}
                {% if opts.picks is empty %}
                    <div class="rounded-md border border-slate-200 p-3">
                        <div class="flex items-baseline justify-between mb-1 gap-3 flex-wrap">
                            <span class="text-sm font-semibold text-slate-900">{{ part }}</span>
                            <span class="t-caption">currently Lvl {{ cur.level }} · {{ cur.start }}% → {{ cur.end }}% if untouched</span>
                        </div>
                        <p class="t-caption">No affordable, survivable option within your group's range.</p>
                    </div>
                {% else %}
                    {# Picks are pre-sorted tier ASC then cost ASC, so opts.picks[0]
                       is the best pick. Highlight the top row only when its tier is
                       Perfect (0) or Top match (1). #}
                    {% set top_pick_qualifies = opts.picks[0].pha_tier in [0, 1] %}
                    {% set best = opts.picks[0] %}
                    {% set best_slot = {
                        'free_downgrade': 'Free downgrade',
                        'downgrade':      'Downgrade',
                        'sidegrade':      'Sidegrade',
                        'upgrade':        'Upgrade',
                    }[best.slot] %}
                    <details data-acc id="swap-{{ part|lower|replace({' ': '-'}) }}" class="group rounded-md border border-slate-200">
                        <summary class="flex cursor-pointer select-none list-none items-start justify-between gap-3 p-3 hover:bg-slate-50">
                            <span class="min-w-0">
                                <span class="text-sm font-semibold text-slate-900">{{ part }} — best: {{ best_slot }} Lvl {{ best.level }} · ends {{ best.end }}% · {{ best.cost > 0 ? '$' ~ best.cost|number_format : 'free' }}</span>
                                <span class="t-caption block mt-0.5">currently Lvl {{ cur.level }} · {{ cur.start }}% → {{ cur.end }}% if untouched</span>
                            </span>
                            <svg class="h-4 w-4 shrink-0 text-slate-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </summary>
                        <div class="border-t border-slate-200 px-3 pb-3 pt-3">
                            <ul class="space-y-2">
                                {% for r in opts.picks %}
                                    {% set slot_label = {
                                        'free_downgrade': 'Free downgrade',
                                        'downgrade':      'Downgrade',
                                        'sidegrade':      'Sidegrade',
                                        'upgrade':        'Upgrade',
                                    }[r.slot] %}
                                    {% set tier_label = {0: 'Perfect', 1: 'Top match'}[r.pha_tier] ?? null %}
                                    {% set tier_bg = {
                                        0: 'bg-emerald-100 text-emerald-800',
                                        1: 'bg-lime-100 text-lime-800',
                                    }[r.pha_tier] ?? '' %}
                                    {% set tier_help = {
                                        0: 'Your car PHA ranking exactly mirrors the track demand — strongest matches most-demanded, all the way down.',
                                        1: 'Your car top attribute matches what the track demands most; the lower two may differ.',
                                    }[r.pha_tier] ?? '' %}
                                    {% set row_bg = loop.first and top_pick_qualifies
                                        ? 'bg-emerald-50 border-emerald-200'
                                        : 'bg-surface border-slate-200' %}
                                    <li class="rounded-md border {{ row_bg }} px-3 py-2">
                                        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                                            <span class="text-xs font-semibold uppercase tracking-wide text-slate-500">{{ slot_label }}</span>
                                            <span class="text-sm font-semibold text-slate-900">Lvl {{ r.level }}</span>
                                            <span class="t-caption">{{ r.cost > 0 ? '$' ~ r.cost|number_format : 'free' }}</span>
                                            <span class="t-caption">ends at {{ r.end }}%</span>
                                            {% if tier_label %}
                                                <span class="ml-auto inline-flex items-center rounded-md px-2 py-0.5 text-xs font-semibold cursor-help {{ tier_bg }}"
                                                      title="{{ tier_help }}">
                                                    {{ tier_label }}
                                                </span>
                                            {% endif %}
                                        </div>
                                        <p class="t-caption mt-1">{{ r.rationale }}</p>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    </details>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}

    <p class="t-caption">
        Move the slider to model different driver-risk levels. The Car Wear tab
        gives the full breakdown.
    </p>

    <details class="group rounded-lg border border-slate-200">
        <summary class="flex cursor-pointer select-none list-none items-center justify-between px-4 py-3 text-xs font-semibold uppercase tracking-wide text-slate-500 hover:bg-slate-50">
            PHA contribution per part
            <svg class="h-4 w-4 shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
        </summary>
        <div class="border-t border-slate-200 px-4 pb-4 pt-3 space-y-3">
            <p class="t-caption pt-1">Use this to manually calculate PHA shifts when swapping parts. Each number is the contribution per level — multiply by the level change to get the delta.</p>
            <table class="w-full text-xs">
                <thead>
                    <tr class="border-b border-slate-200">
                        <th class="pb-1.5 text-left font-semibold text-slate-600">Part</th>
                        <th class="pb-1.5 text-center font-semibold text-blue-600">P</th>
                        <th class="pb-1.5 text-center font-semibold text-amber-600">H</th>
                        <th class="pb-1.5 text-center font-semibold text-emerald-600">A</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% set pha_table = [
                        { part: 'Engine',     p: 6, h: 0, a: 2 },
                        { part: 'Gearbox',    p: 3, h: 1, a: 5 },
                        { part: 'Front Wing', p: 1, h: 3, a: 0 },
                        { part: 'Rear Wing',  p: 0, h: 2, a: 3 },
                        { part: 'Electronics',p: 2, h: 0, a: 2 },
                        { part: 'Chassis',    p: 1, h: 2, a: 2 },
                        { part: 'Suspension', p: 0, h: 2, a: 2 },
                        { part: 'Brakes',     p: 0, h: 2, a: 0 },
                        { part: 'Cooling',    p: 2, h: 0, a: 0 },
                        { part: 'Sidepods',   p: 1, h: 1, a: 0 },
                        { part: 'Underbody',  p: 0, h: 1, a: 1 },
                    ] %}
                    {% for row in pha_table %}
                        <tr>
                            <td class="py-1.5 text-slate-700">{{ row.part }}</td>
                            <td class="py-1.5 text-center {{ row.p > 0 ? 'font-semibold text-blue-600' : 'text-slate-300' }}">{{ row.p > 0 ? row.p : '—' }}</td>
                            <td class="py-1.5 text-center {{ row.h > 0 ? 'font-semibold text-amber-600' : 'text-slate-300' }}">{{ row.h > 0 ? row.h : '—' }}</td>
                            <td class="py-1.5 text-center {{ row.a > 0 ? 'font-semibold text-emerald-600' : 'text-slate-300' }}">{{ row.a > 0 ? row.a : '—' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </details>
</div>
