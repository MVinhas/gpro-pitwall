{# templates/partials/_tab_track_risks.twig #}

<div class="max-w-5xl mx-auto">
    <div class="bg-white rounded-xl shadow-lg border border-slate-200 overflow-hidden">
        
        <div class="border-b border-slate-200 bg-slate-50 px-6 py-8 text-center">
             <h2 class="text-2xl font-bold text-slate-900">Track Configuration</h2>
             <p class="text-slate-500 mt-2">Set ideal risks for <span class="text-blue-600 font-semibold">{{ active_track }}</span></p>
        </div>

        <div class="grid md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-slate-200">
            
            {# Sidebar Selector #}
            <div class="p-6 md:col-span-1 bg-slate-50/50">
                <label class="block text-sm font-medium text-slate-700 mb-2">Select Track</label>
                <select onchange="window.location.href='/?main_tab=Track Risks&track='+encodeURIComponent(this.value)"
                        class="form-select">
                    {# tracks is now [id => name], iterate to get name #}
                    {% for id, name in tracks %}
                        {# Sort alphabetically in Twig is hard without filter, but the list provided was random. 
                           It will appear in order of the config array. #}
                        <option value="{{ name }}" {{ name == active_track ? 'selected' : '' }}>{{ name }}</option>
                    {% endfor %}
                </select>
            </div>

            {# Main Form #}
            <div class="p-6 md:col-span-2">
                <form method="POST" action="/update_track_risks" class="space-y-6">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="track_name" value="{{ active_track }}">
                    
                    <div class="grid grid-cols-2 gap-6">
                        <div>
                            <label class="t-label block mb-1">Overtaking Risk</label>
                            <div class="form-input-group">
                                <input type="number" name="overtaking_risk" value="{{ track_risks.overtaking_risk ?? 50 }}" min="0" max="100" class="form-input">
                                <span class="form-input-addon">%</span>
                            </div>
                        </div>
                        <div>
                            <label class="t-label block mb-1">Defense Risk</label>
                            <div class="form-input-group">
                                <input type="number" name="defense_risk" value="{{ track_risks.defense_risk ?? 50 }}" min="0" max="100" class="form-input">
                                <span class="form-input-addon">%</span>
                            </div>
                        </div>
                    </div>

                    <div class="border-t border-slate-100 pt-6">
                        <h4 class="text-sm font-medium text-slate-900 mb-4">Q1 Dry Risk Settings</h4>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {% for div in divisions %}
                                {% set risk_key = 'q1_' ~ div|lower %}
                                <div>
                                    <label class="block text-xs font-medium text-slate-500 mb-1">{{ div }}</label>
                                    <select name="q1_{{ div }}" class="form-select">
                                        {% for opt in config.app.q1_risk_options %}
                                            <option value="{{ opt }}" {{ track_risks[risk_key] is defined and track_risks[risk_key] == opt ? 'selected' : '' }}>
                                                {{ opt }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                    
                    <div class="pt-4 flex justify-end">
                        <button type="submit" class="inline-flex justify-center rounded-md bg-blue-600 px-6 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 transition-all">
                            Save Configuration
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>