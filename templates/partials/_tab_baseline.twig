<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    
    {# LEFT COLUMN: Division Stats #}
    <div class="lg:col-span-7 flex flex-col gap-6">
        <div class="card">
            <div class="card-hd flex justify-between items-center">
                <h3 class="t-heading">
                    {{ active_division }} Baseline
                    <span class="ml-2 inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
                        {{ all_ideal_pilots[active_division].count }} Pilots
                    </span>
                </h3>
                <span class="t-caption tabular-nums">
                    {% set cap = config.secrets.division_caps[active_division] %}
                    Cap: {{ cap == 999 ? '∞' : cap }} OA
                </span>
            </div>

            <div class="card-bd">
                {% if all_ideal_pilots[active_division].count > 0 %}
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
                        {% for key, val in all_ideal_pilots[active_division].stats %}
                            {% set isOA = (key == 'Overall Ability') %}
                            <div class="relative flex flex-col rounded-lg border {{ isOA ? 'border-blue-200 bg-blue-50 col-span-2 sm:col-span-3 p-4 items-center' : 'border-slate-100 p-3 bg-slate-50' }}">
                                <dt class="t-label">{{ key }}</dt>
                                <dd class="mt-1 font-bold tabular-nums {{ isOA ? 'text-blue-700 text-3xl' : 'text-slate-900 text-xl' }}">
                                    {{ val }}
                                </dd>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-12 bg-slate-50 rounded-lg border-2 border-dashed border-slate-200">
                        <p class="t-caption">No data recorded for {{ active_division }} yet.</p>
                    </div>
                {% endif %}
            </div>
        </div>
        
        {# Division Switcher #}
        <div class="flex justify-center space-x-2 p-1 bg-slate-200 rounded-lg self-center">
            {% for div in divisions %}
                {% set div_cap = config.secrets.division_caps[div] %}
                <a href="?main_tab=Division Baseline&division_tab={{ div }}&track={{ active_track }}"
                   class="flex flex-col items-center px-4 py-2 rounded-md transition-all {{ div == active_division ? 'bg-white text-blue-600 shadow-sm' : 'text-slate-500 hover:text-slate-700' }}">
                    <span class="text-sm font-medium leading-none">{{ div }}</span>
                    <span class="mt-0.5 text-[10px] font-medium uppercase tracking-wide opacity-70">
                        Cap {{ div_cap == 999 ? '∞' : div_cap }}
                    </span>
                </a>
            {% endfor %}
        </div>
    </div>

    {# RIGHT COLUMN: Actions #}
    <div class="lg:col-span-5 flex flex-col gap-6">
        
        {# Add Pilot Card #}
        <div class="card">
            <div class="card-hd">
                <h3 class="t-heading">Add Pilot Data</h3>
            </div>
            <div class="card-bd">
                <form method="POST" action="/add_pilot" class="space-y-4">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="division" value="{{ active_division }}">

                    <div class="grid grid-cols-2 gap-3">
                        {# FIX: Updated variable path to config.app.stats_schema #}
                        {% for display, col in config.app.stats_schema %}
                            <div>
                                <label class="t-label block mb-1">{{ display }}</label>
                                <input type="number" name="{{ col }}" required min="0" max="250" class="form-input-sm">
                            </div>
                        {% endfor %}
                    </div>

                    <button type="submit" class="btn btn-md btn-primary mt-4 w-full">
                        Add to Database
                    </button>
                </form>
            </div>
        </div>

        {# Season Tracker Card #}
        <div class="card">
            <div class="card-bd flex items-center justify-between">
                <div>
                    <h4 class="t-section">Season</h4>
                    <p class="t-caption">Current Data Season</p>
                </div>
                <form method="POST" action="/update_season" class="flex gap-2">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="division" value="{{ active_division }}">
                    {# FIX: Added px-3 for padding #}
                    <input type="number" name="season_number" value="{{ division_metadata.season }}" class="form-input-sm">
                    <button type="submit" class="btn btn-sm btn-secondary">Set</button>
                </form>
            </div>
        </div>

        {# Undo / Clear Buttons #}
        <div class="flex gap-3">
             <form method="POST" action="/undo_last_pilot" class="flex-1"
                   onsubmit="return confirm('Delete the last pilot added to {{ active_division }}? This cannot be undone.');">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <input type="hidden" name="division" value="{{ active_division }}">
                <button type="submit" class="btn btn-md btn-soft-warn w-full shadow-sm">
                    Undo Last
                </button>
            </form>
            <form method="POST" action="/clear_stats" class="flex-1"
                  onsubmit="return confirm('Delete ALL {{ all_ideal_pilots[active_division].count }} pilot record(s) for {{ active_division }}? This cannot be undone.');">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <input type="hidden" name="division" value="{{ active_division }}">
                <button type="submit" class="btn btn-md btn-soft-danger w-full shadow-sm">
                    Clear All
                </button>
            </form>
        </div>
    </div>
</div>