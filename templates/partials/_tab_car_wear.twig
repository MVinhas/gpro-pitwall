<div class="mb-4 rounded-md bg-amber-50 border-l-4 border-amber-400 p-4 shadow-sm">
    <p class="text-sm text-amber-800">
        <span class="font-bold">Changed the car?</span>
        Re-sync first — these projections use your last-synced car data{% if user.last_synced_at %} (last sync: {{ user.last_synced_at|date("M j, H:i") }}){% endif %}.
    </p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

    {# LEFT: Controls #}
    <div class="lg:col-span-4">
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
                <h3 class="t-heading">Race Analysis</h3>
            </div>

            <div class="p-6">
                {% if wear_error %}
                    <div class="mb-4 p-3 bg-red-50 text-red-700 text-sm rounded border border-red-200">
                        {{ wear_error }}
                    </div>
                {% endif %}

                <form method="POST" action="/calculate_wear" id="wearForm">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                    {# Driver Stats Section — read-only, fetched from the GPRO API. #}
                    <div class="mb-6 p-4 bg-slate-50 rounded-lg border border-slate-100">
                        <div class="flex items-baseline justify-between mb-3">
                            <h4 class="t-section">Driver Stats</h4>
                        </div>
                        {% if wear_inputs.driver is defined %}
                            <div class="grid grid-cols-3 gap-3">
                                <div>
                                    <span class="t-label block mb-1">Concentration</span>
                                    <span class="t-value block">{{ wear_inputs.driver.concentration }}</span>
                                </div>
                                <div>
                                    <span class="t-label block mb-1">Talent</span>
                                    <span class="t-value block">{{ wear_inputs.driver.talent }}</span>
                                </div>
                                <div>
                                    <span class="t-label block mb-1">Experience</span>
                                    <span class="t-value block">{{ wear_inputs.driver.experience }}</span>
                                </div>
                            </div>
                        {% else %}
                            <p class="t-caption">No driver data — sync your account first.</p>
                        {% endif %}
                    </div>

                    <div class="mb-6">
                        <label class="t-label block mb-2">Clear Track Risk</label>
                        <div class="flex items-center gap-4">
                            <input type="range" name="risk" min="0" max="100" value="{{ wear_inputs.risk ?? 0 }}"
                                   data-wear-risk-slider
                                   class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer"
                                   oninput="document.getElementById('riskVal').innerText = this.value">
                            <span id="riskVal" class="text-sm font-bold text-blue-600 w-8 tabular-nums">{{ wear_inputs.risk ?? 0 }}</span>
                        </div>
                        <p class="t-caption mt-2">Move the slider — projection refreshes automatically.</p>
                    </div>
                </form>
            </div>

            <div class="bg-slate-50 px-6 py-4 border-t border-slate-200 t-caption">
                <p>Calculates wear based on Track Characteristics, Car Level, and Driver Stats.</p>
            </div>
        </div>
    </div>

    {# RIGHT: Results (live-refreshed on slider change) #}
    <div class="lg:col-span-8" id="wear-results-card">
        {% include 'partials/_car_wear_results.twig' %}
    </div>
</div>

<script>
(() => {
    const slider = document.querySelector('[data-wear-risk-slider]');
    const card = document.getElementById('wear-results-card');
    const form = document.getElementById('wearForm');
    if (!slider || !card || !form) return;

    let pending = null;

    slider.addEventListener('change', async () => {
        if (pending) pending.abort();
        pending = new AbortController();
        const data = new FormData(form);
        try {
            const res = await fetch('/car_wear_fragment', {
                method: 'POST',
                body: data,
                signal: pending.signal,
                headers: { 'X-Requested-With': 'fetch' },
            });
            if (!res.ok) return;
            card.innerHTML = await res.text();
        } catch (err) {
            if (err.name !== 'AbortError') console.error(err);
        }
    });
})();
</script>