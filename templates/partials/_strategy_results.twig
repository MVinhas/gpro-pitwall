{% if strategy_error == no_pilot_message %}
    <div class="mb-6">{% include 'partials/_no_pilot_notice.twig' %}</div>
{% elseif strategy_error %}
    <div class="mb-6 rounded-md bg-red-50 border-l-4 border-red-400 p-4 shadow-sm">
        <div class="flex">
            <svg class="h-5 w-5 text-red-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
            </svg>
            <div class="ml-3">
                <p class="text-sm font-bold text-red-800">Strategy calculation failed</p>
                <p class="text-sm text-red-700 mt-1">{{ strategy_error }}</p>
            </div>
        </div>
    </div>
{% endif %}

{% if strategy_results and strategy_results.error is defined %}
    <div class="rounded-md bg-amber-50 border-l-4 border-amber-400 p-4 shadow-sm">
        <p class="text-sm font-bold text-amber-800">{{ strategy_results.error }}</p>
    </div>
{% elseif strategy_results and strategy_results.track is defined %}
    <div class="space-y-6">
        {# HEADER #}
        <div class="flex justify-between items-center border-b border-slate-200 pb-4">
            <div>
                <h2 class="t-display">{{ strategy_results.track }}</h2>
                <p class="t-caption">
                    Season {{ strategy_results.season }} Race {{ strategy_results.race }} • {{ strategy_results.inputs.laps }} Laps
                </p>
            </div>
            <div class="text-right">
                <p class="text-xl font-bold text-blue-600 tabular-nums">{{ strategy_results.supplier }}</p>
                {% if strategy_results.supplier_info %}
                    {% set si = strategy_results.supplier_info %}
                    <p class="mt-1 text-xs tabular-nums" title="Your tyre supplier's characteristics — not the track.">
                        <span class="text-slate-400">Tyres</span>
                        {% if si.dry is not null %}<span class="ml-2 text-slate-400">Dry</span><span class="ml-1 text-slate-700">{{ si.dry }}/8</span>{% endif %}
                        {% if si.wet is not null %}<span class="ml-2 text-slate-400">Wet</span><span class="ml-1 text-slate-700">{{ si.wet }}/8</span>{% endif %}
                        {% if si.temp is not null %}<span class="ml-2 text-slate-400">Ideal temp</span><span class="ml-1 text-slate-700">{{ si.temp }}°C</span>{% endif %}
                    </p>
                {% endif %}
            </div>
        </div>

        {# FUEL + TRACK BILLBOARD #}
        <div class="flex flex-wrap items-center divide-x divide-slate-300 text-xs font-medium tabular-nums">
            <span class="px-3 first:pl-0">
                <span class="text-slate-400">Consumption</span>
                <span class="ml-1 text-slate-700">{{ strategy_results.fuel.l_per_lap }} L/lap</span>
            </span>
            <span class="px-3">
                <span class="text-slate-400">Fuel (dry)</span>
                <span class="ml-1 text-slate-700">{{ strategy_results.fuel.dry }} L</span>
            </span>
            <span class="px-3">
                <span class="text-slate-400">Fuel (wet)</span>
                <span class="ml-1 text-slate-700">{{ strategy_results.fuel.wet }} L</span>
            </span>
            {% if strategy_results.overtaking %}
                {% set ot_class = {
                    'Very Easy': 'text-emerald-700',
                    'Easy':      'text-emerald-700',
                    'Normal':    'text-slate-700',
                    'Hard':      'text-amber-700',
                    'Very Hard': 'text-red-700',
                }[strategy_results.overtaking] ?? 'text-slate-700' %}
                <span class="px-3 last:pr-0"
                      title="How easily cars pass here. Hard overtaking makes track position more valuable — favour fewer pit stops.">
                    <span class="text-slate-400">Overtaking</span>
                    <span class="ml-1 font-bold {{ ot_class }}">{{ strategy_results.overtaking }}</span>
                </span>
            {% endif %}
        </div>

        {# RACE ENGINEER (heuristic advisor, not a game formula) — accordion #}
        {% if strategy_results.risk_advice is defined %}
            {% set ra = strategy_results.risk_advice %}
            <details open id="race-engineer" class="bg-white rounded-xl shadow-sm border border-slate-200 group">
                <summary class="cursor-pointer list-none p-6 flex flex-wrap items-center justify-between gap-4">
                    <span class="flex items-center gap-3">
                        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-blue-600 shadow-sm">
                            {# Race-engineer headset with mic boom #}
                            <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 13.5v-2.25a7.5 7.5 0 0 1 15 0v2.25"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 13.5A1.5 1.5 0 0 1 6 12h.75a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5H6a1.5 1.5 0 0 1-1.5-1.5v-3Z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 13.5a1.5 1.5 0 0 1 1.5-1.5H18a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-.75a1.5 1.5 0 0 1-1.5-1.5v-3Z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 18v.375a2.625 2.625 0 0 1-2.625 2.625H13.5"/>
                            </svg>
                        </span>
                        <span>
                            <h4 class="t-section">Advice from the Race Engineer</h4>
                            <p class="t-caption mt-0.5">Risks, start, problem policy and boost laps</p>
                        </span>
                    </span>
                    <span class="flex items-center gap-6 text-right">
                        <span>
                            <p class="text-2xl font-bold text-blue-600 tabular-nums">{{ ra.overtake }}</p>
                            <p class="t-caption">Overtake risk</p>
                        </span>
                        <span class="border-l pl-6 border-slate-100">
                            <p class="text-2xl font-bold text-blue-600 tabular-nums">{{ ra.defend }}</p>
                            <p class="t-caption">Defend risk</p>
                        </span>
                        <span class="text-slate-400 group-open:rotate-90 transition-transform" aria-hidden="true">▸</span>
                    </span>
                </summary>
                <div class="px-6 pb-6">
                    <p class="text-sm text-slate-600">{{ ra.phrase }}</p>
                    {% if ra.tip %}
                        <p class="text-sm text-slate-600 mt-2">{{ ra.tip }}</p>
                    {% endif %}
                    {% if ra.distance_tip %}
                        <p class="text-sm text-slate-600 mt-2">{{ ra.distance_tip }}</p>
                    {% endif %}
                    {% if ra.settings is defined %}
                        <div class="mt-4 pt-4 border-t border-slate-100 grid gap-4 sm:grid-cols-2">
                            <div>
                                <p class="t-label">Race start</p>
                                <p class="text-sm font-semibold text-slate-800 mt-0.5">{{ ra.settings.start_approach }}</p>
                                <p class="text-xs text-slate-500 mt-0.5">Start risk stacks with race risks.</p>
                            </div>
                            <div>
                                <p class="t-label">Pit on solvable problem</p>
                                <p class="text-sm font-semibold text-slate-800 mt-0.5">Yes, if &gt; {{ ra.settings.problem_pit_laps }} laps remain</p>
                                <p class="text-xs text-slate-500 mt-0.5">A repair stop beats limping 3&ndash;6 s/lap.</p>
                            </div>
                        </div>
                    {% endif %}
                    {% if ra.boost is defined and ra.boost.laps|length > 0 %}
                        <div class="mt-4 pt-4 border-t border-slate-100">
                            <div class="flex flex-wrap items-center gap-2">
                                <p class="t-label">Suggested boost laps</p>
                                {% for lap in ra.boost.laps %}
                                    <span class="inline-flex items-center rounded-md bg-blue-50 px-2.5 py-0.5 text-sm font-bold text-blue-700 tabular-nums">{{ lap }}</span>
                                {% endfor %}
                            </div>
                            <p class="text-sm text-slate-600 mt-2">{{ ra.boost.note }}</p>
                        </div>
                    {% endif %}
                    <p class="text-xs text-slate-400 mt-4">Heuristic guidance from your driver, track and forecast — not a game formula.</p>
                </div>
            </details>
        {% endif %}

        {# STRATEGY TABLE #}
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-800">
                        <tr>
                            <th rowspan="2" class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wide text-white">Compound</th>
                            <th rowspan="2" class="px-4 py-3 text-center text-xs font-bold uppercase tracking-wide text-white">Stops</th>
                            <th colspan="2" class="px-4 py-2 text-center text-xs font-bold uppercase tracking-wide text-white border-b border-slate-700">Fuel / Stint</th>
                            <th rowspan="2" class="px-4 py-3 text-center text-xs font-bold uppercase tracking-wide text-white">Est. Pit</th>
                            <th rowspan="2" class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wide text-slate-400 border-l border-slate-600">Lost (Pits)</th>
                            <th rowspan="2" class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wide text-slate-400">Lost (Fuel)</th>
                            <th rowspan="2" class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wide text-slate-400">Lost (TCD)</th>
                            <th rowspan="2" class="px-4 py-3 text-center text-xs font-bold uppercase tracking-wide text-white bg-slate-900">Total Lost</th>
                        </tr>
                        <tr>
                            <th class="px-3 py-1.5 text-center text-[10px] font-medium uppercase tracking-wide text-slate-400" title="Bare-minimum fuel to finish the stint; no safety margin.">Minimum</th>
                            <th class="px-3 py-1.5 text-center text-[10px] font-medium uppercase tracking-wide text-slate-400" title="Minimum + 1 extra lap of fuel — buffer against bad pit timing.">Recommended</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-200">
                        {% for comp, data in strategy_results.tyres %}
                            {% set is_best = (comp == strategy_results.best_compound) %}
                            <tr class="transition-colors {{ is_best ? 'bg-emerald-50 hover:bg-emerald-100' : 'hover:bg-slate-50' }}">
                                <td class="px-4 py-3 text-sm font-bold text-slate-900">
                                    {% if is_best %}
                                        <span class="inline-flex items-center rounded-md bg-emerald-600 px-2 py-0.5 text-[10px] font-bold text-white mr-2 align-middle">★ Best</span>
                                    {% endif %}
                                    {{ comp }}
                                </td>
                                <td class="px-4 py-3 text-center text-sm font-bold tabular-nums {{ data.stops > 3 ? 'text-red-500' : (is_best ? 'text-emerald-700' : 'text-blue-600') }}">
                                    {{ data.stops }}
                                </td>
                                <td class="px-3 py-3 text-center text-sm text-slate-500 tabular-nums">{{ data.fuel_load }} L</td>
                                <td class="px-3 py-3 text-center text-sm font-semibold tabular-nums {{ is_best ? 'text-emerald-700' : 'text-blue-600' }}">{{ data.fuel_recommended }} L</td>
                                <td class="px-4 py-3 text-center text-sm text-slate-500 tabular-nums">{{ data.pit_time_est }}s</td>

                                <td class="px-4 py-3 text-center text-xs text-slate-500 tabular-nums border-l border-slate-100">
                                    {{ data.lost_pits }}
                                </td>
                                <td class="px-4 py-3 text-center text-xs text-slate-500 tabular-nums">
                                    {{ data.lost_fuel }}
                                </td>
                                <td class="px-4 py-3 text-center text-xs text-slate-500 tabular-nums">
                                    {{ data.lost_tcd }}
                                </td>

                                <td class="px-4 py-3 text-center text-sm font-bold tabular-nums border-l border-slate-200 {{ is_best ? 'text-emerald-700 bg-emerald-100' : 'text-slate-900 bg-slate-50' }}">
                                    {{ data.total_lost }}s
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# SETUP CALCULATOR TABLE #}
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-3 bg-slate-50 border-b border-slate-200">
                <h3 class="t-section">Car Setup</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200 text-sm">
                    <thead>
                        <tr class="bg-white">
                            <th class="px-4 py-3 text-left align-bottom"><span class="t-label">Part</span></th>

                            {# Q1 Column — API-derived, read-only #}
                            <th class="px-4 py-3 text-center border-l border-slate-200 w-36">
                                <span class="block font-bold text-slate-700 mb-1">Qualifying 1</span>
                                <div class="flex justify-center gap-2 items-center text-xs text-slate-600">
                                    <span class="font-semibold">{{ strategy_results.weather_inputs.Q1.temp }}°C</span>
                                    <span class="px-1.5 py-0.5 rounded {{ strategy_results.weather_inputs.Q1.weather == 'Wet' ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-700' }}">
                                        {{ strategy_results.weather_inputs.Q1.weather }}
                                    </span>
                                </div>
                                <input form="stratForm" type="hidden" name="q1_temp" value="{{ strategy_results.weather_inputs.Q1.temp }}">
                                <input form="stratForm" type="hidden" name="q1_weather" value="{{ strategy_results.weather_inputs.Q1.weather }}">
                            </th>

                            {# Q2 Column — API-derived, read-only #}
                            <th class="px-4 py-3 text-center border-l border-slate-200 w-36">
                                <span class="block font-bold text-slate-700 mb-1">Qualifying 2</span>
                                <div class="flex justify-center gap-2 items-center text-xs text-slate-600">
                                    <span class="font-semibold">{{ strategy_results.weather_inputs.Q2.temp }}°C</span>
                                    <span class="px-1.5 py-0.5 rounded {{ strategy_results.weather_inputs.Q2.weather == 'Wet' ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-700' }}">
                                        {{ strategy_results.weather_inputs.Q2.weather }}
                                    </span>
                                </div>
                                <input form="stratForm" type="hidden" name="q2_temp" value="{{ strategy_results.weather_inputs.Q2.temp }}">
                                <input form="stratForm" type="hidden" name="q2_weather" value="{{ strategy_results.weather_inputs.Q2.weather }}">
                            </th>

                            {# Race Column — weather is the only knob; changing it re-runs the calc #}
                            <th class="px-4 py-3 text-center border-l border-slate-200 bg-blue-50 w-48">
                                <span class="block font-bold text-blue-800 mb-1">Race</span>
                                <div class="flex justify-center gap-2 items-center">
                                    <span class="text-xs font-bold px-2">{{ strategy_results.inputs.temp }}°C</span>
                                    <select form="stratForm" name="race_weather"
                                            data-strategy-fragment-trigger
                                            class="form-select w-24 text-xs py-1">
                                        <option value="Dry" {{ strategy_results.weather_inputs.Race.weather == 'Dry' ? 'selected' }}>Dry</option>
                                        <option value="Wet" {{ strategy_results.weather_inputs.Race.weather == 'Wet' ? 'selected' }}>Wet</option>
                                    </select>
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200">
                        {% for part in ['Front Wing', 'Rear Wing', 'Engine', 'Brakes', 'Gearbox', 'Suspension'] %}
                            <tr class="hover:bg-slate-50">
                                <td class="px-4 py-2.5 font-bold text-slate-700 pl-6">{{ part }}</td>
                                <td class="px-4 py-2.5 text-center font-mono tabular-nums text-slate-600 border-l border-slate-100">{{ strategy_results.setups.Q1[part] }}</td>
                                <td class="px-4 py-2.5 text-center font-mono tabular-nums text-slate-600 border-l border-slate-100">{{ strategy_results.setups.Q2[part] }}</td>
                                <td class="px-4 py-2.5 text-center font-mono text-base font-bold tabular-nums text-blue-700 bg-blue-50 border-l border-blue-100">
                                    {{ strategy_results.setups.Race[part] }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="px-6 py-3 border-t border-slate-100">
                <p class="text-xs text-slate-500">
                    Values above 999 should be entered as 999 in GPRO — we don't clamp them, so if your driver complains you know why.
                </p>
            </div>
        </div>

    </div>
{% else %}
    <div class="h-full flex flex-col items-center justify-center bg-slate-50 rounded-xl border border-dashed border-slate-200 p-12">
        <p class="t-heading">Strategy &amp; Setup</p>
        <p class="t-caption mt-1">Click "Calculate Strategy" to simulate race outcomes.</p>
    </div>
{% endif %}
