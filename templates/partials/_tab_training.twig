<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    
    {# LEFT COLUMN: Pilot Data Form #}
    <div class="lg:col-span-5 flex flex-col gap-6">
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-200 bg-slate-50 flex justify-between items-center">
                <h3 class="t-heading">Driver Profile</h3>

                {# API Import Button #}
                <form method="POST" action="/import_driver">
                    <input type="hidden" name="action" value="import_driver">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    {% if can_submit %}
                        <button type="submit" class="btn btn-sm btn-primary">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                            </svg>
                            Load My Pilot
                        </button>
                    {% else %}
                        <button type="button" disabled title="Requires Premium + API Token" class="btn btn-sm btn-disabled">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                            </svg>
                            Load My Pilot
                        </button>
                    {% endif %}
                </form>
            </div>

            <div class="p-6">
                {% if training_error %}
                    <div class="mb-4 rounded-md bg-red-50 p-3 text-sm text-red-700 border border-red-200">
                        {{ training_error }}
                    </div>
                {% endif %}

                <form method="POST" action="/calculate_training">
                    <input type="hidden" name="action" value="calculate_training">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                    {% set driver = imported_driver ?? {} %}

                    <div class="grid grid-cols-2 gap-4">
                        {% for key, label in config.app.stats_schema %}
                            <div>
                                <label class="t-label block mb-1">{{ label }}</label>
                                <input type="number" name="{{ key|lower }}" value="{{ driver[key|lower] ?? 0 }}" required class="form-input-sm">
                            </div>
                        {% endfor %}
                    </div>

                    <div class="mt-6 pt-6 border-t border-slate-100">
                        <h4 class="t-section mb-3">Training Schedule</h4>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="col-span-2 sm:col-span-1">
                                <label class="t-label block mb-1">Program</label>
                                <select name="training_type" class="form-select">
                                    {% for t in trainings %}
                                        <option value="{{ t.name }}">{{ t.name }} (${{ t.cost|number_format }})</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-span-2 sm:col-span-1">
                                <label class="t-label block mb-1">Sessions</label>
                                <input type="number" name="intensity" value="1" min="1" max="20" class="form-input-sm">
                            </div>
                        </div>
                    </div>

                    <div class="mt-6">
                        {% if can_submit %}
                            <button type="submit" class="btn btn-md btn-primary w-full">
                                Calculate Projection
                            </button>
                        {% else %}
                            <div class="p-4 bg-amber-50 border border-amber-200 rounded-md text-center">
                                <p class="text-sm font-medium text-amber-800 mb-2">
                                    {% if not is_logged_in %}
                                        Account Required
                                    {% elseif not user.is_premium %}
                                        Premium Feature
                                    {% else %}
                                        Setup Required
                                    {% endif %}
                                </p>
                                <p class="t-caption text-amber-700 mb-3">
                                    {% if not is_logged_in %}
                                        Log in to calculate training.
                                    {% elseif not user.is_premium %}
                                        Upgrade to Premium to use the Planner.
                                    {% else %}
                                        Add API Key in Control Panel.
                                    {% endif %}
                                </p>
                                <button type="button" disabled class="btn btn-md btn-disabled w-full">
                                    Calculate Projection (Locked)
                                </button>
                            </div>
                        {% endif %}
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# RIGHT COLUMN: Results & Analysis #}
    <div class="lg:col-span-7">
        {% if training_results %}
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-200 bg-slate-50 flex justify-between items-center">
                    <h3 class="text-lg font-semibold text-slate-800">Projected Results</h3>
                    <span class="inline-flex items-center rounded-md bg-blue-100 px-2 py-1 text-xs font-medium text-blue-700">
                        {{ training_results.program }}
                    </span>
                </div>
                
                <div class="p-6">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                        {# Summary Card #}
                        <div class="bg-slate-50 rounded-lg p-4 border border-slate-100 text-center">
                            <p class="text-xs text-slate-500 uppercase tracking-wide">Total Cost</p>
                            <p class="text-xl font-bold text-emerald-600">${{ training_results.total_cost|number_format }}</p>
                        </div>
                        
                        {# Key Stat Changes #}
                        <div class="md:col-span-2 bg-white border border-slate-100 rounded-lg p-4">
                            <p class="text-xs text-slate-500 uppercase tracking-wide mb-2">Attribute Changes</p>
                            <div class="flex flex-wrap gap-2">
                                {% for key, startVal in training_results.start %}
                                    {% set endVal = training_results.end[key] %}
                                    {% set diff = endVal - startVal %}
                                    {% if diff != 0 %}
                                        <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset {{ diff > 0 ? 'bg-green-50 text-green-700 ring-green-600/20' : 'bg-red-50 text-red-700 ring-red-600/20' }}">
                                            {{ key|capitalize }}: {{ diff > 0 ? '+' : '' }}{{ diff }}
                                        </span>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    {# Comparison Table #}
                    <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
                        <table class="min-w-full divide-y divide-slate-300">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-slate-900">Attribute</th>
                                    <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-slate-900">Current</th>
                                    <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-slate-900">Projected</th>
                                    <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-slate-900">Change</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-200 bg-white">
                                {% for key, startVal in training_results.start %}
                                    {% set endVal = training_results.end[key] %}
                                    {% set diff = endVal - startVal %}
                                    <tr class="hover:bg-slate-50">
                                        <td class="whitespace-nowrap py-3 pl-4 pr-3 text-sm font-medium text-slate-700 capitalize">{{ key }}</td>
                                        <td class="whitespace-nowrap px-3 py-3 text-center text-sm text-slate-500">{{ startVal }}</td>
                                        <td class="whitespace-nowrap px-3 py-3 text-center text-sm font-bold text-slate-900">{{ endVal }}</td>
                                        <td class="whitespace-nowrap px-3 py-3 text-center text-sm font-medium {{ diff > 0 ? 'text-emerald-600' : (diff < 0 ? 'text-red-600' : 'text-slate-300') }}">
                                            {{ diff > 0 ? '+' : '' }}{{ diff != 0 ? diff : '-' }}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        {% else %}
            {# Empty State #}
            <div class="h-full flex flex-col items-center justify-center text-center p-12 bg-slate-50 border border-dashed border-slate-200 rounded-xl">
                <svg class="h-12 w-12 text-slate-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                </svg>
                <h3 class="text-sm font-medium text-slate-900">Ready to Plan</h3>
                <p class="mt-1 text-sm text-slate-500">Import your driver or enter stats manually to start planning.</p>
            </div>
        {% endif %}
    </div>
</div>