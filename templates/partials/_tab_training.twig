<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    
    {# LEFT COLUMN: Pilot Data Form #}
    <div class="lg:col-span-5 flex flex-col gap-6">
        <div class="card">
            <div class="card-hd">
                <h3 class="t-heading">Driver Profile</h3>
            </div>

            <div class="card-bd">
                {% if training_error %}
                    <div class="mb-4 notice notice-error">
                        {{ training_error }}
                    </div>
                {% endif %}

                <form method="POST" action="/calculate_training">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                    {% set driver = imported_driver ?? {} %}

                    <details data-acc data-acc-lg-open id="training-stats" class="group rounded-lg border border-slate-200">
                        <summary class="flex cursor-pointer select-none list-none items-center justify-between px-4 py-3 hover:bg-slate-50">
                            <span>
                                <span class="text-sm font-semibold text-slate-800">Driver stats</span>
                                <span class="t-caption block mt-0.5">9 attributes — imported from your last sync, editable</span>
                            </span>
                            <svg class="h-4 w-4 shrink-0 text-slate-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="border-t border-slate-200 px-4 pb-4 pt-3">
                            <div class="grid grid-cols-2 gap-4">
                                {# stats_schema is {DisplayLabel: column_name}. Render the
                                   display label, use the column name as the form key. #}
                                {% for display, column in config.app.stats_schema %}
                                    <div>
                                        <label class="t-label block mb-1">{{ display }}</label>
                                        <input type="number" name="{{ column }}" value="{{ driver[column] ?? 0 }}" required class="form-input-sm">
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </details>

                    <details data-acc data-acc-lg-open id="training-schedule" class="group mt-4 rounded-lg border border-slate-200">
                        <summary class="flex cursor-pointer select-none list-none items-center justify-between px-4 py-3 hover:bg-slate-50">
                            <span>
                                <span class="text-sm font-semibold text-slate-800">Training schedule</span>
                                <span class="t-caption block mt-0.5">Sessions per program, applied in listed order</span>
                            </span>
                            <svg class="h-4 w-4 shrink-0 text-slate-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="border-t border-slate-200 px-4 pb-4 pt-3">
                            <p class="t-caption mb-3">
                                Set how many sessions of each program. The plan applies them in the
                                listed order and projects the cumulative result.
                            </p>
                            <div class="space-y-2">
                                {% for t in trainings %}
                                    <div class="flex items-center justify-between gap-3 rounded-md border border-slate-200 px-3 py-2">
                                        <div>
                                            <p class="text-sm font-medium text-slate-800">{{ t.name }}</p>
                                            <p class="t-caption">${{ t.cost|number_format }} / session</p>
                                        </div>
                                        <input type="number"
                                               name="sessions[{{ t.name }}]"
                                               value="{{ schedule[t.name] ?? 0 }}"
                                               min="0" max="20"
                                               data-cost="{{ t.cost }}"
                                               class="form-input-sm">
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </details>

                    {% set total_sessions = 0 %}{% set total_cost = 0 %}
                    {% for t in trainings %}{% set n = schedule[t.name] ?? 0 %}{% set total_sessions = total_sessions + n %}{% set total_cost = total_cost + (n * t.cost) %}{% endfor %}
                    <div class="mt-4 flex items-center justify-between rounded-md bg-slate-50 border border-slate-200 px-3 py-2 text-sm" data-training-totals>
                        <span class="font-medium text-slate-700">Total</span>
                        <span class="tabular-nums text-slate-800"><span data-total-sessions>{{ total_sessions }}</span> sessions · $<span data-total-cost>{{ total_cost|number_format }}</span></span>
                    </div>

                    <div class="mt-6">
                        {% if can_submit %}
                            <button type="submit" class="btn btn-md btn-primary w-full">
                                Calculate Projection
                            </button>
                        {% else %}
                            <div class="p-4 bg-amber-50 border border-amber-200 rounded-md text-center">
                                <p class="text-sm font-medium text-amber-800 mb-2">Account Required</p>
                                <p class="t-caption text-amber-700 mb-3">
                                    <a href="/login" class="underline hover:text-amber-900">Log in</a>
                                    or
                                    <a href="/register" class="underline hover:text-amber-900">register</a>
                                    to calculate training.
                                </p>
                                <button type="button" disabled class="btn btn-md btn-disabled w-full">
                                    Calculate Projection (Locked)
                                </button>
                            </div>
                        {% endif %}
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# RIGHT COLUMN: Results & Analysis #}
    <div class="lg:col-span-7">
        {% if training_results %}
            <div class="card">
                <div class="card-hd flex justify-between items-center">
                    <h3 class="t-heading">Projected Results</h3>
                    <span class="inline-flex items-center rounded-md bg-blue-100 px-2 py-1 text-xs font-medium text-blue-700">
                        {{ training_results.program }}
                    </span>
                </div>

                <div class="card-bd">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                        {# Summary Cards #}
                        <div class="bg-slate-50 rounded-lg p-4 border border-slate-100 text-center">
                            <p class="text-xs text-slate-500 uppercase tracking-wide">Total Cost</p>
                            <p class="text-xl font-bold text-emerald-600">${{ training_results.total_cost|number_format }}</p>
                        </div>

                        {% if training_results.start_oa is defined %}
                            {% set oa_delta = training_results.end_oa - training_results.start_oa %}
                            <div class="bg-slate-50 rounded-lg p-4 border border-slate-100 text-center">
                                <p class="text-xs text-slate-500 uppercase tracking-wide">Overall Ability</p>
                                <p class="text-xl font-bold text-slate-800 tabular-nums">
                                    {{ training_results.start_oa }} → {{ training_results.end_oa }}
                                </p>
                                <p class="text-xs {{ oa_delta > 0 ? 'text-emerald-600' : (oa_delta < 0 ? 'text-red-600' : 'text-slate-500') }}">
                                    {{ oa_delta > 0 ? '+' : '' }}{{ oa_delta }} OA
                                </p>
                            </div>
                        {% endif %}

                        {# Key Stat Changes #}
                        <div class="md:col-span-1 bg-white border border-slate-100 rounded-lg p-4">
                            <p class="text-xs text-slate-500 uppercase tracking-wide mb-2">Attribute Changes</p>
                            <div class="flex flex-wrap gap-2">
                                {% for key, startVal in training_results.start %}
                                    {% set endVal = training_results.end[key] %}
                                    {% set diff = endVal - startVal %}
                                    {% if diff != 0 %}
                                        <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset {{ diff > 0 ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20' : 'bg-red-50 text-red-700 ring-red-600/20' }}">
                                            {{ key|capitalize }}: {{ diff > 0 ? '+' : '' }}{{ diff }}
                                        </span>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    {# Comparison Table #}
                    <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
                        <table class="min-w-full divide-y divide-slate-300">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-slate-900">Attribute</th>
                                    <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-slate-900">Current</th>
                                    <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-slate-900">Projected</th>
                                    <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-slate-900">Change</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-200 bg-white">
                                {% for key, startVal in training_results.start %}
                                    {% set endVal = training_results.end[key] %}
                                    {% set diff = endVal - startVal %}
                                    <tr class="hover:bg-slate-50">
                                        <td class="whitespace-nowrap py-3 pl-4 pr-3 text-sm font-medium text-slate-700 capitalize">{{ key }}</td>
                                        <td class="whitespace-nowrap px-3 py-3 text-center text-sm text-slate-500">{{ startVal }}</td>
                                        <td class="whitespace-nowrap px-3 py-3 text-center text-sm font-bold text-slate-900">{{ endVal }}</td>
                                        <td class="whitespace-nowrap px-3 py-3 text-center text-sm font-medium {{ diff > 0 ? 'text-emerald-600' : (diff < 0 ? 'text-red-600' : 'text-slate-300') }}">
                                            {{ diff > 0 ? '+' : '' }}{{ diff != 0 ? diff : '-' }}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        {% else %}
            {# Empty State #}
            <div class="h-full flex flex-col items-center justify-center text-center p-12 bg-slate-50 border border-dashed border-slate-200 rounded-xl">
                <svg class="h-12 w-12 text-slate-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                </svg>
                <h3 class="text-sm font-medium text-slate-900">Ready to Plan</h3>
                <p class="mt-1 text-sm text-slate-500">Import your driver or enter stats manually to start planning.</p>
            </div>
        {% endif %}
    </div>
</div>

<script>
(() => {
    const inputs = document.querySelectorAll('input[name^="sessions["]');
    const sessionsEl = document.querySelector('[data-total-sessions]');
    const costEl = document.querySelector('[data-total-cost]');
    if (!inputs.length || !sessionsEl || !costEl) return;

    const recompute = () => {
        let sessions = 0;
        let cost = 0;
        inputs.forEach((input) => {
            const n = parseInt(input.value, 10) || 0;
            sessions += n;
            cost += n * (parseFloat(input.dataset.cost) || 0);
        });
        sessionsEl.textContent = sessions;
        costEl.textContent = cost.toLocaleString('en-US');
    };

    inputs.forEach((input) => input.addEventListener('input', recompute));
})();
</script>