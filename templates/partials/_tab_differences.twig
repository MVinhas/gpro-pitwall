<div class="space-y-6">
    <div class="text-center">
        <h2 class="t-display">Division Differences</h2>
        <p class="t-caption mt-1">Analyze the jump in requirements between levels.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {% for key, data in insights_data %}
            <div class="card">
                <div class="card-hd">
                    <h3 class="text-base font-semibold text-slate-800 flex items-center gap-2">
                        <span class="bg-surface border border-slate-200 px-2 py-1 rounded text-xs text-slate-500">{{ data.from }}</span>
                        <span class="text-slate-400">→</span>
                        <span class="bg-blue-50 border border-blue-100 px-2 py-1 rounded text-xs text-blue-700 font-bold">{{ data.to }}</span>
                    </h3>
                </div>
                
                <div class="card-bd">
                    {% if data.has_data %}
                        <ul class="space-y-3">
                            {% for stat, info in data.insights %}
                                <li class="flex justify-between items-center text-sm">
                                    <span class="text-slate-600 font-medium">{{ stat }}</span>
                                    <div class="flex items-center gap-3">
                                        <span class="text-xs text-slate-400">{{ info.lower }} → {{ info.higher }}</span>
                                        <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset 
                                            {{ info.diff > 0 ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20' : 'bg-slate-50 text-slate-600 ring-slate-500/10' }}">
                                            {{ info.diff > 0 ? '+' : '' }}{{ info.diff }}
                                        </span>
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                        {% if data.max_diff_key %}
                            <div class="mt-4 pt-4 border-t border-slate-100">
                                <p class="text-xs text-slate-500">
                                    Biggest jump: <strong class="text-slate-800">{{ data.max_diff_key }}</strong>
                                </p>
                            </div>
                        {% endif %}
                    {% else %}
                        <div class="py-8 text-center">
                            <p class="text-sm text-slate-400 italic">Insufficient data to compare.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
</div>