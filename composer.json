{
    "name": "mvinhas/gpro-pitwall",
    "description": "Race-weekend cockpit for GPRO managers — strategy, wear, training, recruitment.",
    "version": "1.2.4",
    "homepage": "https://gpro-pitwall.com",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "Micael Vinhas",
            "email": "admin@gpro-pitwall.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-curl": "*",
        "ext-intl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-sqlite3": "*",
        "phpmailer/phpmailer": "^7.0",
        "twig/twig": "^3.27"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.2",
        "squizlabs/php_codesniffer": "^4.0",
        "sserbin/twig-linter": "^3.1.2",
        "symfony/var-dumper": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "analyse": "phpstan analyse src --level=7 --memory-limit=512M",
        "lint": "phpcs --standard=PSR12 src",
        "twig-lint": "vendor/bin/twig-linter lint templates",
        "audit": "composer audit",
        "refactor": "rector process src",
        "test": "phpunit",
        "check": [
            "@lint",
            "@analyse",
            "@twig-lint",
            "@test"
        ],
        "install-hooks": "ln -sf ../../bin/git_hooks/pre-commit .git/hooks/pre-commit && echo 'Pre-commit hook installed.'"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
